<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="gui.controller.KhuyenMaiController"
      spacing="14" style="-fx-padding:20;">

    <HBox styleClass="card" alignment="CENTER_LEFT" spacing="12"
          style="-fx-padding:12 16;-fx-background-radius:8;">
        <TextField fx:id="txtSearch" styleClass="search-field" promptText="🔍 Tìm tên, mã khuyến mãi..."/>
        <ComboBox fx:id="cmbLoai" promptText="Loại KM" style="-fx-min-width:140px;"/>
        <Button text="Tìm" styleClass="btn-primary,btn-sm" onAction="#handleSearch"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="+ Thêm KM" styleClass="btn-success" onAction="#handleThem"/>
        <Button fx:id="btnSua" text="✏ Sửa" styleClass="btn-warning" onAction="#handleSua"/>
        <Button fx:id="btnXoa" text="✕ Xóa" styleClass="btn-danger" onAction="#handleXoa"/>
    </HBox>

    <HBox spacing="14" VBox.vgrow="ALWAYS">
        <VBox styleClass="card" HBox.hgrow="ALWAYS" spacing="0" style="-fx-padding:0;-fx-background-radius:8;">
            <Label text="Danh Sách Khuyến Mãi"
                   style="-fx-font-size:14px;-fx-font-weight:bold;-fx-text-fill:#1E2A3A;-fx-padding:12 16;"/>
            <TableView fx:id="tableKhuyenMai" VBox.vgrow="ALWAYS" onMouseClicked="#handleRowSelect">
                <columns>
                    <TableColumn fx:id="colMaKM" text="Mã KM" prefWidth="100"/>
                    <TableColumn fx:id="colTenKM" text="Tên Khuyến Mãi" prefWidth="180"/>
                    <TableColumn fx:id="colLoai" text="Loại" prefWidth="120"/>
                    <TableColumn fx:id="colGiaTri" text="Giá Trị" prefWidth="120"/>
                    <TableColumn fx:id="colNgayBD" text="Từ Ngày" prefWidth="120"/>
                    <TableColumn fx:id="colNgayKT" text="Đến Ngày" prefWidth="120"/>
                    <TableColumn fx:id="colDieuKien" text="Điều Kiện" prefWidth="160"/>
                    <TableColumn fx:id="colTrangThai" text="Trạng Thái" prefWidth="110"/>
                </columns>
            </TableView>
        </VBox>

        <VBox styleClass="card" minWidth="300" maxWidth="320" spacing="12">
            <Label fx:id="lblFormTitle" text="Thông Tin Khuyến Mãi"
                   style="-fx-font-size:14px;-fx-font-weight:bold;"/>
            <Separator/>
            <GridPane hgap="8" vgap="10">
                <columnConstraints>
                    <ColumnConstraints minWidth="100"/>
                    <ColumnConstraints hgrow="ALWAYS"/>
                </columnConstraints>
                <Label text="Mã KM:" styleClass="form-label" GridPane.rowIndex="0"/>
                <TextField fx:id="txtMaKM" editable="false" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                <Label text="Tên KM *:" styleClass="form-label" GridPane.rowIndex="1"/>
                <TextField fx:id="txtTenKM" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                <Label text="Loại KM *:" styleClass="form-label" GridPane.rowIndex="2"/>
                <ComboBox fx:id="cmbLoaiKM" GridPane.rowIndex="2" GridPane.columnIndex="1" maxWidth="Infinity"/>
                <Label text="Giá trị (% hoặc đ):" styleClass="form-label" GridPane.rowIndex="3"/>
                <TextField fx:id="txtGiaTri" GridPane.rowIndex="3" GridPane.columnIndex="1"/>
                <Label text="Từ ngày *:" styleClass="form-label" GridPane.rowIndex="4"/>
                <DatePicker fx:id="dpNgayBD" GridPane.rowIndex="4" GridPane.columnIndex="1" maxWidth="Infinity"/>
                <Label text="Đến ngày *:" styleClass="form-label" GridPane.rowIndex="5"/>
                <DatePicker fx:id="dpNgayKT" GridPane.rowIndex="5" GridPane.columnIndex="1" maxWidth="Infinity"/>
                <Label text="Điều kiện:" styleClass="form-label" GridPane.rowIndex="6"/>
                <TextArea fx:id="txtDieuKien" prefRowCount="2" GridPane.rowIndex="6" GridPane.columnIndex="1" wrapText="true"/>
                <Label text="Mô tả:" styleClass="form-label" GridPane.rowIndex="7"/>
                <TextArea fx:id="txtMoTa" prefRowCount="2" GridPane.rowIndex="7" GridPane.columnIndex="1" wrapText="true"/>
            </GridPane>
            <Region VBox.vgrow="ALWAYS"/>
            <HBox spacing="8">
                <Button text="💾 Lưu" styleClass="btn-primary" maxWidth="Infinity" HBox.hgrow="ALWAYS" onAction="#handleSave"/>
                <Button text="✕ Hủy" styleClass="btn-secondary" maxWidth="Infinity" HBox.hgrow="ALWAYS" onAction="#handleCancel"/>
            </HBox>
        </VBox>
    </HBox>
</VBox>