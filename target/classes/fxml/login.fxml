<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.text.*?>

<StackPane xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="gui.controller.LoginController"
           stylesheets="@../css/login.css"
           styleClass="login-root">

    <VBox styleClass="login-card" alignment="CENTER" spacing="14">

        <!-- Logo -->
        <VBox styleClass="login-logo-area" alignment="CENTER" spacing="6">
            <StackPane styleClass="login-logo-circle">
                <Label text="🖥" styleClass="login-logo-icon"/>
            </StackPane>
            <Label text="TIỆM NET ONLINE" styleClass="login-app-name"/>
            <Label text="Hệ thống quản lý tiệm Internet" styleClass="login-app-sub"/>
        </VBox>

        <Separator/>

        <Label text="ĐĂNG NHẬP" styleClass="login-title"/>
        <Label text="Vui lòng chọn vai trò và nhập thông tin" styleClass="login-subtitle"/>

        <!-- Role Toggle -->
        <HBox styleClass="login-role-toggle" alignment="CENTER" spacing="0">
            <ToggleButton fx:id="btnRoleKhachHang" text="👤  Khách hàng"
                          styleClass="login-role-btn" selected="true"
                          onAction="#handleRoleToggle"/>
            <ToggleButton fx:id="btnRoleNhanVien" text="🏢  Nhân viên"
                          styleClass="login-role-btn"
                          onAction="#handleRoleToggle"/>
        </HBox>

        <!-- Username -->
        <VBox spacing="4">
            <Label text="Tên đăng nhập" styleClass="form-label"/>
            <HBox styleClass="login-field-icon-box" alignment="CENTER_LEFT" spacing="8">
                <Label text="👤" styleClass="login-icon"/>
                <TextField fx:id="txtUsername" promptText="Nhập tên đăng nhập"
                           styleClass="login-text-field" HBox.hgrow="ALWAYS"/>
            </HBox>
        </VBox>

        <!-- Password -->
        <VBox spacing="4">
            <Label text="Mật khẩu" styleClass="form-label"/>
            <HBox styleClass="login-field-icon-box" alignment="CENTER_LEFT" spacing="8">
                <Label text="🔒" styleClass="login-icon"/>
                <PasswordField fx:id="txtPassword" promptText="Nhập mật khẩu"
                               styleClass="login-text-field" HBox.hgrow="ALWAYS"/>
            </HBox>
        </VBox>

        <!-- Error -->
        <Label fx:id="lblError" styleClass="login-error-label" text="" wrapText="true" maxWidth="320"/>

        <!-- Login Button -->
        <Button fx:id="btnLogin" text="ĐĂNG NHẬP" styleClass="login-btn"
                maxWidth="Infinity" onAction="#handleLogin"/>

        <Separator/>

        <!-- Register link -->
        <HBox alignment="CENTER" spacing="5">
            <Label text="Chưa có tài khoản?" style="-fx-text-fill: #888888; -fx-font-size: 13px;"/>
            <Button text="Đăng ký ngay" styleClass="login-register-link" onAction="#handleRegister"/>
        </HBox>

        <Label text="© 2026 Quản Lý Tiệm Net v1.0" styleClass="login-footer"/>

    </VBox>
</StackPane>
