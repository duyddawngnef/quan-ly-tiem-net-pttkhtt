<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="gui.controller.LoginController"
           styleClass="login-root"
           stylesheets="@../css/style.css,@../css/login.css"
           prefWidth="900" prefHeight="600">

    <!-- Background gradient overlay -->
    <VBox alignment="CENTER" spacing="0">
        <!-- Logo area top -->
        <VBox alignment="CENTER" spacing="4" VBox.vgrow="ALWAYS">
            <Label text="🖥 QUẢN LÝ TIỆM NET" styleClass="sidebar-logo-text"
                   style="-fx-font-size:28px;-fx-text-fill:white;-fx-font-weight:bold;"/>
            <Label text="Hệ thống quản lý chuyên nghiệp" style="-fx-text-fill:#90CAF9;-fx-font-size:13px;"/>
        </VBox>
    </VBox>

    <!-- Login card centered -->
    <VBox alignment="CENTER">
        <VBox styleClass="login-card" spacing="0">

            <!-- Card Header -->
            <VBox alignment="CENTER" spacing="6" style="-fx-padding:0 0 24 0;">
                <Label text="🖥 NetManager" styleClass="login-logo-text"/>
                <Label text="Quản Lý Tiệm Net" styleClass="login-subtitle"/>
            </VBox>

            <Separator style="-fx-padding:0 0 20 0;"/>

            <!-- Form -->
            <VBox spacing="16" style="-fx-padding:20 0 0 0;">

                <Label text="ĐĂNG NHẬP HỆ THỐNG" styleClass="login-title"
                       style="-fx-padding:0 0 8 0;"/>

                <!-- Username -->
                <VBox spacing="4">
                    <Label text="Tên đăng nhập" styleClass="login-label"/>
                    <TextField fx:id="txtUsername" styleClass="login-field"
                               promptText="Nhập tên đăng nhập..."/>
                </VBox>

                <!-- Password -->
                <VBox spacing="4">
                    <Label text="Mật khẩu" styleClass="login-label"/>
                    <PasswordField fx:id="txtPassword" styleClass="login-field"
                                   promptText="Nhập mật khẩu..."/>
                </VBox>

                <!-- Role -->
                <VBox spacing="4">
                    <Label text="Vai trò" styleClass="login-label"/>
                    <ComboBox fx:id="cmbRole" promptText="Chọn vai trò"
                              style="-fx-pref-width:340px; -fx-pref-height:40px;"/>
                </VBox>

                <!-- Error label -->
                <Label fx:id="lblError" styleClass="login-error" text="" wrapText="true"/>

                <!-- Login button -->
                <Button fx:id="btnLogin" text="ĐĂNG NHẬP" styleClass="login-btn"
                        onAction="#handleLogin" defaultButton="true"
                        style="-fx-padding:0;"/>

                <!-- Register link -->
                <HBox alignment="CENTER" spacing="4">
                    <Label text="Chưa có tài khoản?" style="-fx-font-size:12px;-fx-text-fill:#757575;"/>
                    <Hyperlink text="Đăng ký" styleClass="register-link" onAction="#handleRegister"/>
                </HBox>

            </VBox>
        </VBox>
    </VBox>

</StackPane>