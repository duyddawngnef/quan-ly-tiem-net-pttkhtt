<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="gui.controller.MainController"
            stylesheets="@../css/style.css"
            prefWidth="1280" prefHeight="760">

    <!-- ===== SIDEBAR ===== -->
    <left>
        <VBox styleClass="sidebar" spacing="0">

            <!-- Logo -->
            <VBox styleClass="sidebar-logo-area" spacing="4">
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="🖥" style="-fx-font-size:26px; -fx-text-fill:#FFFFFF;"/>
                    <VBox spacing="2">
                        <Label text="TIỆM NET" styleClass="sidebar-logo-text"/>
                        <Label text="Quản lý hệ thống" styleClass="sidebar-logo-sub"/>
                    </VBox>
                </HBox>
            </VBox>

            <!-- User info strip -->
            <HBox spacing="10" alignment="CENTER_LEFT"
                  style="-fx-background-color:#1A3255; -fx-padding: 12 15 12 15;">
                <StackPane styleClass="header-avatar">
                    <Label fx:id="lblAvatarChar" text="A"
                           style="-fx-text-fill:#FFFFFF; -fx-font-weight:bold; -fx-font-size:14px;"/>
                </StackPane>
                <VBox spacing="2">
                    <Label fx:id="lblUserName" text="Tên người dùng"
                           style="-fx-text-fill:#FFFFFF; -fx-font-size:13px; -fx-font-weight:bold;"/>
                    <Label fx:id="lblUserRole" text="Vai trò"
                           style="-fx-text-fill:#90CAF9; -fx-font-size:11px;"/>
                </VBox>
            </HBox>

            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                        style="-fx-background-color:transparent; -fx-border-color:transparent;">
                <VBox spacing="2" style="-fx-padding: 8 0 8 0;">

                    <!-- DASHBOARD -->
                    <Label text="TỔNG QUAN" styleClass="sidebar-section-label"/>
                    <Button fx:id="btnSoDoMay" text="🗺  Sơ đồ máy"
                            styleClass="menu-button" onAction="#loadSoDoMay"/>

                    <!-- VẬN HÀNH -->
                    <Label text="VẬN HÀNH" styleClass="sidebar-section-label"/>
                    <Button fx:id="btnPhienSuDung" text="⏱  Phiên sử dụng"
                            styleClass="menu-button" onAction="#loadPhienSuDung"/>
                    <Button fx:id="btnNapTien" text="💳  Nạp tiền"
                            styleClass="menu-button" onAction="#loadNapTien"/>
                    <Button fx:id="btnHoaDon" text="🧾  Hóa đơn"
                            styleClass="menu-button" onAction="#loadHoaDon"/>

                    <!-- DỊCH VỤ -->
                    <Label text="DỊCH VỤ" styleClass="sidebar-section-label"/>
                    <Button fx:id="btnDichVu" text="🥤  Dịch vụ"
                            styleClass="menu-button" onAction="#loadDichVu"/>
                    <Button fx:id="btnGoiDichVu" text="📦  Gói dịch vụ"
                            styleClass="menu-button" onAction="#loadGoiDichVu"/>
                    <Button fx:id="btnKhuyenMai" text="🎁  Khuyến mãi"
                            styleClass="menu-button" onAction="#loadKhuyenMai"/>
                    <Button fx:id="btnNhapHang" text="📥  Nhập hàng"
                            styleClass="menu-button" onAction="#loadNhapHang"/>

                    <!-- QUẢN LÝ -->
                    <Label text="QUẢN LÝ" styleClass="sidebar-section-label"/>
                    <Button fx:id="btnKhachHang" text="👥  Khách hàng"
                            styleClass="menu-button" onAction="#loadKhachHang"/>
                    <Button fx:id="btnNhanVien" text="🏢  Nhân viên"
                            styleClass="menu-button" onAction="#loadNhanVien"/>
                    <Button fx:id="btnMayTinh" text="💻  Máy tính"
                            styleClass="menu-button" onAction="#loadMayTinh"/>
                    <Button fx:id="btnKhuMay" text="🗂  Khu máy"
                            styleClass="menu-button" onAction="#loadKhuMay"/>

                    <!-- BÁO CÁO -->
                    <Label text="BÁO CÁO" styleClass="sidebar-section-label"/>
                    <Button fx:id="btnThongKe" text="📊  Thống kê"
                            styleClass="menu-button" onAction="#loadThongKe"/>

                </VBox>
            </ScrollPane>

            <!-- Logout button -->
            <VBox style="-fx-padding: 0 0 8 0;">
                <Separator style="-fx-padding: 4 0 4 0;"/>
                <Button text="🔓  Đăng xuất" styleClass="menu-button"
                        style="-fx-text-fill:#FF8A80;" onAction="#handleLogout"/>
            </VBox>

        </VBox>
    </left>

    <!-- ===== CONTENT AREA ===== -->
    <center>
        <VBox spacing="0">
            <!-- Header bar -->
            <HBox styleClass="header-bar" alignment="CENTER_LEFT" spacing="14">
                <Label fx:id="lblPageTitle" text="Sơ đồ máy" styleClass="header-title"
                       HBox.hgrow="ALWAYS"/>
                <Label fx:id="lblCurrentTime" text="00:00:00"
                       style="-fx-text-fill:#888888; -fx-font-size:13px;"/>
            </HBox>

            <!-- Dynamic content -->
            <StackPane fx:id="contentPane" VBox.vgrow="ALWAYS"
                       styleClass="content-area"/>
        </VBox>
    </center>

</BorderPane>
