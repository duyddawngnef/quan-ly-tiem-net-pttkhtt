<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="gui.controller.NapTienController"
      stylesheets="@../css/style.css"
      spacing="16" style="-fx-padding: 0;">

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="12">
        <Label text="💳" style="-fx-font-size:26px;"/>
        <VBox spacing="2">
            <Label text="Nạp Tiền Tài Khoản" styleClass="page-title"/>
            <Label text="Nạp tiền cho khách hàng và áp dụng khuyến mãi" styleClass="page-subtitle"/>
        </VBox>
    </HBox>

    <HBox spacing="16" VBox.vgrow="ALWAYS">

        <!-- Left: Input form -->
        <VBox spacing="14" styleClass="page-card" prefWidth="420" minWidth="360">
            <Label text="Thông tin nạp tiền" style="-fx-font-size:15px; -fx-font-weight:bold; -fx-text-fill:#1565C0;"/>
            <Separator/>

            <!-- Find customer -->
            <VBox spacing="4">
                <Label text="Tìm khách hàng *" styleClass="form-label"/>
                <HBox spacing="6">
                    <TextField fx:id="txtTimKH" promptText="Mã KH hoặc tên đăng nhập"
                               styleClass="text-field" HBox.hgrow="ALWAYS"/>
                    <Button text="🔍  Tìm" styleClass="btn btn-outline" onAction="#handleTimKH"/>
                </HBox>
            </VBox>

            <!-- Customer info display -->
            <VBox fx:id="vboxKHInfo" spacing="8" style="-fx-background-color:#EBF5FB;
                  -fx-background-radius:8; -fx-padding:14; -fx-border-color:#BBDEFB;
                  -fx-border-width:1; -fx-border-radius:8;" visible="false" managed="false">
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <StackPane styleClass="header-avatar">
                        <Label fx:id="lblKHAvatar" text="K"
                               style="-fx-text-fill:#FFFFFF; -fx-font-weight:bold;"/>
                    </StackPane>
                    <VBox spacing="3">
                        <Label fx:id="lblKHTen" text="" style="-fx-font-weight:bold; -fx-font-size:14px;"/>
                        <Label fx:id="lblKHSDT" text="" styleClass="page-subtitle"/>
                    </VBox>
                </HBox>
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <Label text="Số dư hiện tại:" style="-fx-text-fill:#555555;"/>
                    <Label fx:id="lblKHSoDu" text="0 ₫" styleClass="currency-label"/>
                </HBox>
            </VBox>

            <!-- Amount -->
            <VBox spacing="4">
                <Label text="Số tiền nạp (VNĐ) *" styleClass="form-label"/>
                <TextField fx:id="txtSoTien" promptText="VD: 100000"
                           styleClass="text-field" onKeyReleased="#handleSoTienChanged"/>
                <!-- Quick amounts -->
                <HBox spacing="6" style="-fx-padding: 4 0 0 0;">
                    <Button text="50.000" styleClass="btn btn-outline"
                            style="-fx-font-size:11px; -fx-padding:4 8;"
                            onAction="#handleQuickAmount50"/>
                    <Button text="100.000" styleClass="btn btn-outline"
                            style="-fx-font-size:11px; -fx-padding:4 8;"
                            onAction="#handleQuickAmount100"/>
                    <Button text="200.000" styleClass="btn btn-outline"
                            style="-fx-font-size:11px; -fx-padding:4 8;"
                            onAction="#handleQuickAmount200"/>
                    <Button text="500.000" styleClass="btn btn-outline"
                            style="-fx-font-size:11px; -fx-padding:4 8;"
                            onAction="#handleQuickAmount500"/>
                </HBox>
            </VBox>

            <!-- CTKM -->
            <VBox spacing="4">
                <Label text="Chương trình khuyến mãi" styleClass="form-label"/>
                <ComboBox fx:id="cboCTKM" promptText="Không áp dụng" styleClass="combo-box"
                          maxWidth="Infinity" onAction="#handleCTKMChanged"/>
            </VBox>

            <!-- Calculated bonus -->
            <VBox fx:id="vboxKM" spacing="6" style="-fx-background-color:#F1F8E9;
                  -fx-background-radius:6; -fx-padding:12; -fx-border-color:#C5E1A5;
                  -fx-border-width:1; -fx-border-radius:6;" visible="false" managed="false">
                <HBox>
                    <Label text="Tiền KM thêm:" style="-fx-text-fill:#555555;" HBox.hgrow="ALWAYS"/>
                    <Label fx:id="lblTienKM" text="0 ₫" style="-fx-text-fill:#388E3C; -fx-font-weight:bold;"/>
                </HBox>
            </VBox>

            <!-- Summary -->
            <VBox spacing="6" style="-fx-background-color:#EBF2FA; -fx-background-radius:8;
                  -fx-padding:14; -fx-border-color:#BBDEFB; -fx-border-width:1; -fx-border-radius:8;">
                <HBox>
                    <Label text="Tiền nạp:" style="-fx-text-fill:#555555;" HBox.hgrow="ALWAYS"/>
                    <Label fx:id="lblSoTienFmt" text="0 ₫" style="-fx-font-weight:bold;"/>
                </HBox>
                <HBox>
                    <Label text="Tiền khuyến mãi:" style="-fx-text-fill:#555555;" HBox.hgrow="ALWAYS"/>
                    <Label fx:id="lblTienKMFmt" text="0 ₫" style="-fx-text-fill:#388E3C;"/>
                </HBox>
                <Separator/>
                <HBox>
                    <Label text="Tổng cộng nhận được:" style="-fx-font-weight:bold;" HBox.hgrow="ALWAYS"/>
                    <Label fx:id="lblTongCong" text="0 ₫" styleClass="currency-label" style="-fx-font-size:16px;"/>
                </HBox>
            </VBox>

            <Label fx:id="lblError" styleClass="error-label" text="" wrapText="true"/>

            <Button fx:id="btnNapTien" text="💳  XÁC NHẬN NẠP TIỀN" styleClass="btn btn-primary"
                    maxWidth="Infinity" style="-fx-font-size:14px; -fx-padding:12;"
                    onAction="#handleNapTien"/>
        </VBox>

        <!-- Right: History -->
        <VBox spacing="12" VBox.vgrow="ALWAYS" HBox.hgrow="ALWAYS" styleClass="page-card" style="-fx-padding:0;">
            <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding:16 16 12 16;
                  -fx-border-color:transparent transparent #E8EEF6 transparent; -fx-border-width:0 0 1 0;">
                <Label text="Lịch sử nạp tiền" style="-fx-font-size:15px; -fx-font-weight:bold; -fx-text-fill:#1565C0;"/>
                <Pane HBox.hgrow="ALWAYS"/>
                <DatePicker fx:id="dateFilter" promptText="Từ ngày" prefWidth="140"/>
                <Button text="🔍  Lọc" styleClass="btn btn-outline" onAction="#handleFilterHistory"/>
            </HBox>
            <TableView fx:id="tableHistory" VBox.vgrow="ALWAYS" style="-fx-background-radius:0;">
                <TableColumn fx:id="colMaNT" text="Mã NT" prefWidth="80"/>
                <TableColumn fx:id="colKHHist" text="Khách hàng" prefWidth="160"/>
                <TableColumn fx:id="colSoTienHist" text="Số tiền" prefWidth="110"/>
                <TableColumn fx:id="colKMHist" text="KM" prefWidth="80"/>
                <TableColumn fx:id="colTongHist" text="Tổng nhận" prefWidth="110"/>
                <TableColumn fx:id="colNVHist" text="Nhân viên" prefWidth="130"/>
                <TableColumn fx:id="colNgayHist" text="Ngày nạp" prefWidth="130"/>
            </TableView>
        </VBox>
    </HBox>

</VBox>
