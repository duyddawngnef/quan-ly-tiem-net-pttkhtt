<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="gui.controller.GoiDichVuController"
      spacing="14" style="-fx-padding:20;">

    <HBox styleClass="card" alignment="CENTER_LEFT" spacing="12"
          style="-fx-padding:12 16;-fx-background-radius:8;">
        <TextField fx:id="txtSearch" styleClass="search-field" promptText="🔍 Tìm tên gói..."/>
        <Button text="Tìm" styleClass="btn-primary,btn-sm" onAction="#handleSearch"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="+ Thêm Gói" styleClass="btn-success" onAction="#handleThem"/>
        <Button fx:id="btnSua" text="✏ Sửa" styleClass="btn-warning" onAction="#handleSua"/>
        <Button fx:id="btnXoa" text="✕ Xóa" styleClass="btn-danger" onAction="#handleXoa"/>
    </HBox>

    <HBox spacing="14" VBox.vgrow="ALWAYS">
        <!-- Gói list -->
        <VBox styleClass="card" HBox.hgrow="ALWAYS" spacing="0" style="-fx-padding:0;-fx-background-radius:8;">
            <Label text="Danh Sách Gói Dịch Vụ"
                   style="-fx-font-size:14px;-fx-font-weight:bold;-fx-text-fill:#1E2A3A;-fx-padding:12 16;"/>
            <TableView fx:id="tableGoi" VBox.vgrow="ALWAYS" onMouseClicked="#handleRowSelect">
                <columns>
                    <TableColumn fx:id="colMaGoi" text="Mã Gói" prefWidth="90"/>
                    <TableColumn fx:id="colTenGoi" text="Tên Gói" prefWidth="160"/>
                    <TableColumn fx:id="colSoGio" text="Số Giờ" prefWidth="90"/>
                    <TableColumn fx:id="colGia" text="Giá (đ)" prefWidth="120"/>
                    <TableColumn fx:id="colUuDai" text="Ưu Đãi %" prefWidth="100"/>
                    <TableColumn fx:id="colHanSuDung" text="Hạn SD (ngày)" prefWidth="130"/>
                    <TableColumn fx:id="colMoTa" text="Mô Tả" prefWidth="200"/>
                    <TableColumn fx:id="colTrangThai" text="Trạng Thái" prefWidth="110"/>
                </columns>
            </TableView>
        </VBox>

        <!-- Form -->
        <VBox styleClass="card" minWidth="290" maxWidth="310" spacing="12">
            <Label fx:id="lblFormTitle" text="Thông Tin Gói DV"
                   style="-fx-font-size:14px;-fx-font-weight:bold;"/>
            <Separator/>
            <GridPane hgap="8" vgap="10">
                <columnConstraints>
                    <ColumnConstraints minWidth="95"/>
                    <ColumnConstraints hgrow="ALWAYS"/>
                </columnConstraints>
                <Label text="Mã gói:" styleClass="form-label" GridPane.rowIndex="0"/>
                <TextField fx:id="txtMaGoi" editable="false" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                <Label text="Tên gói *:" styleClass="form-label" GridPane.rowIndex="1"/>
                <TextField fx:id="txtTenGoi" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                <Label text="Số giờ *:" styleClass="form-label" GridPane.rowIndex="2"/>
                <TextField fx:id="txtSoGio" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
                <Label text="Giá (đ) *:" styleClass="form-label" GridPane.rowIndex="3"/>
                <TextField fx:id="txtGia" GridPane.rowIndex="3" GridPane.columnIndex="1"/>
                <Label text="Ưu đãi (%):" styleClass="form-label" GridPane.rowIndex="4"/>
                <TextField fx:id="txtUuDai" promptText="0" GridPane.rowIndex="4" GridPane.columnIndex="1"/>
                <Label text="Hạn SD (ngày):" styleClass="form-label" GridPane.rowIndex="5"/>
                <TextField fx:id="txtHanSuDung" promptText="30" GridPane.rowIndex="5" GridPane.columnIndex="1"/>
                <Label text="Mô tả:" styleClass="form-label" GridPane.rowIndex="6"/>
                <TextArea fx:id="txtMoTa" prefRowCount="3" GridPane.rowIndex="6" GridPane.columnIndex="1" wrapText="true"/>
            </GridPane>
            <Region VBox.vgrow="ALWAYS"/>
            <HBox spacing="8">
                <Button text="💾 Lưu" styleClass="btn-primary" maxWidth="Infinity" HBox.hgrow="ALWAYS" onAction="#handleSave"/>
                <Button text="✕ Hủy" styleClass="btn-secondary" maxWidth="Infinity" HBox.hgrow="ALWAYS" onAction="#handleCancel"/>
            </HBox>
        </VBox>
    </HBox>
</VBox>