<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="gui.controller.KhuMayController"
      spacing="14" style="-fx-padding:20;">

    <HBox styleClass="card" alignment="CENTER_LEFT" spacing="12"
          style="-fx-padding:12 16;-fx-background-radius:8;">
        <TextField fx:id="txtSearch" styleClass="search-field" promptText="🔍 Tìm tên khu máy..."/>
        <Button text="Tìm" styleClass="btn-primary,btn-sm" onAction="#handleSearch"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="+ Thêm Khu" styleClass="btn-success" onAction="#handleThem"/>
        <Button fx:id="btnSua" text="✏ Sửa" styleClass="btn-warning" onAction="#handleSua"/>
        <Button fx:id="btnXoa" text="✕ Xóa" styleClass="btn-danger" onAction="#handleXoa"/>
    </HBox>

    <HBox spacing="14" VBox.vgrow="ALWAYS">
        <VBox styleClass="card" HBox.hgrow="ALWAYS" spacing="0" style="-fx-padding:0;-fx-background-radius:8;">
            <Label text="Danh Sách Khu Máy"
                   style="-fx-font-size:14px;-fx-font-weight:bold;-fx-text-fill:#1E2A3A;-fx-padding:12 16;"/>
            <TableView fx:id="tableKhuMay" VBox.vgrow="ALWAYS" onMouseClicked="#handleRowSelect">
                <columns>
                    <TableColumn fx:id="colMaKhu" text="Mã Khu" prefWidth="100"/>
                    <TableColumn fx:id="colTenKhu" text="Tên Khu" prefWidth="200"/>
                    <TableColumn fx:id="colViTri" text="Vị Trí" prefWidth="150"/>
                    <TableColumn fx:id="colSoMay" text="Số Máy" prefWidth="100"/>
                    <TableColumn fx:id="colGhiChu" text="Ghi Chú" prefWidth="250"/>
                </columns>
            </TableView>
        </VBox>

        <VBox styleClass="card" minWidth="280" maxWidth="300" spacing="12">
            <Label fx:id="lblFormTitle" text="Thông Tin Khu Máy"
                   style="-fx-font-size:14px;-fx-font-weight:bold;"/>
            <Separator/>
            <GridPane hgap="8" vgap="10">
                <columnConstraints>
                    <ColumnConstraints minWidth="85"/>
                    <ColumnConstraints hgrow="ALWAYS"/>
                </columnConstraints>
                <Label text="Mã khu:" styleClass="form-label" GridPane.rowIndex="0"/>
                <TextField fx:id="txtMaKhu" editable="false" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                <Label text="Tên khu *:" styleClass="form-label" GridPane.rowIndex="1"/>
                <TextField fx:id="txtTenKhu" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                <Label text="Vị trí:" styleClass="form-label" GridPane.rowIndex="2"/>
                <TextField fx:id="txtViTri" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
                <Label text="Ghi chú:" styleClass="form-label" GridPane.rowIndex="3"/>
                <TextArea fx:id="txtGhiChu" prefRowCount="3" GridPane.rowIndex="3" GridPane.columnIndex="1" wrapText="true"/>
            </GridPane>
            <Region VBox.vgrow="ALWAYS"/>
            <HBox spacing="8">
                <Button text="💾 Lưu" styleClass="btn-primary" maxWidth="Infinity" HBox.hgrow="ALWAYS" onAction="#handleSave"/>
                <Button text="✕ Hủy" styleClass="btn-secondary" maxWidth="Infinity" HBox.hgrow="ALWAYS" onAction="#handleCancel"/>
            </HBox>
        </VBox>
    </HBox>
</VBox>