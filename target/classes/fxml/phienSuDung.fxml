<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>
<?import javafx.collections.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="gui.controller.PhienSuDungController"
      stylesheets="@../css/style.css"
      spacing="16" style="-fx-padding: 0;">

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="12">
        <Label text="⏱" style="-fx-font-size:26px;"/>
        <VBox spacing="2">
            <Label text="Quản Lý Phiên Sử Dụng" styleClass="page-title"/>
            <Label fx:id="lblSubtitle" text="Đang tải..." styleClass="page-subtitle"/>
        </VBox>
        <Pane HBox.hgrow="ALWAYS"/>
        <Label fx:id="lblLiveTime" text="🕐 00:00:00"
               style="-fx-text-fill:#1565C0; -fx-font-size:16px; -fx-font-weight:bold;"/>
    </HBox>

    <!-- Stats -->
    <HBox spacing="12">
        <VBox styleClass="stat-card stat-card-blue" spacing="4" HBox.hgrow="ALWAYS">
            <Label fx:id="lblDangChoi" text="0" styleClass="stat-number" style="-fx-text-fill:#1565C0;"/>
            <Label text="Phiên đang chơi" styleClass="stat-label"/>
        </VBox>
        <VBox styleClass="stat-card stat-card-green" spacing="4" HBox.hgrow="ALWAYS">
            <Label fx:id="lblDoanhThuNgay" text="0 ₫" styleClass="stat-number" style="-fx-text-fill:#388E3C; -fx-font-size:18px;"/>
            <Label text="Doanh thu hôm nay" styleClass="stat-label"/>
        </VBox>
        <VBox styleClass="stat-card" spacing="4" HBox.hgrow="ALWAYS">
            <Label fx:id="lblPhienHomNay" text="0" styleClass="stat-number"/>
            <Label text="Phiên hôm nay" styleClass="stat-label"/>
        </VBox>
    </HBox>

    <!-- Toolbar -->
    <HBox styleClass="toolbar" spacing="8" alignment="CENTER_LEFT">
        <TextField fx:id="txtSearch" promptText="🔍  Tìm KH, máy..." styleClass="search-bar"
                   prefWidth="220" onKeyReleased="#handleSearch"/>
        <ComboBox fx:id="cboTrangThai" promptText="Trạng thái" styleClass="combo-box" prefWidth="150"
                  onAction="#handleFilter">
        </ComboBox>
        <Pane HBox.hgrow="ALWAYS"/>
        <Button fx:id="btnMoPhien" text="▶  Mở phiên mới" styleClass="btn btn-success"
                onAction="#handleMoPhien"/>
        <Button fx:id="btnKetThuc" text="■  Kết thúc" styleClass="btn btn-danger"
                onAction="#handleKetThucPhien" disable="true"/>
        <Button fx:id="btnOrderDV" text="🥤  Order DV" styleClass="btn btn-warning"
                onAction="#handleOrderDichVu" disable="true"/>
        <Button text="↺" styleClass="btn btn-secondary" onAction="#handleRefresh"/>
    </HBox>

    <!-- Table -->
    <VBox VBox.vgrow="ALWAYS" styleClass="page-card" spacing="0" style="-fx-padding:0;">
        <TableView fx:id="tableView" VBox.vgrow="ALWAYS">
            <TableColumn fx:id="colMaPhien" text="Mã phiên" prefWidth="90"/>
            <TableColumn fx:id="colMaMay" text="Máy" prefWidth="80"/>
            <TableColumn fx:id="colKhachHang" text="Khách hàng" prefWidth="160"/>
            <TableColumn fx:id="colNhanVien" text="NV mở" prefWidth="130"/>
            <TableColumn fx:id="colGioBD" text="Giờ bắt đầu" prefWidth="140"/>
            <TableColumn fx:id="colThoiGian" text="Thời gian" prefWidth="100"/>
            <TableColumn fx:id="colTienTam" text="Tiền tạm (₫)" prefWidth="120"/>
            <TableColumn fx:id="colTrangThai" text="Trạng thái" prefWidth="120"/>
        </TableView>
        <HBox alignment="CENTER_RIGHT" spacing="12"
              style="-fx-padding:10 16; -fx-background-color:#FAFBFF;
                     -fx-border-color:#E8EEF6 transparent transparent transparent; -fx-border-width:1 0 0 0;">
            <Label fx:id="lblTotal" text="Tổng: 0 phiên" styleClass="page-subtitle"/>
        </HBox>
    </VBox>

</VBox>
