<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="gui.controller.NhanVienController"
      spacing="14" style="-fx-padding:20;">

    <HBox styleClass="card" alignment="CENTER_LEFT" spacing="12"
          style="-fx-padding:12 16;-fx-background-radius:8;">
        <TextField fx:id="txtSearch" styleClass="search-field" promptText="🔍 Tìm theo mã, tên, SĐT..."/>
        <ComboBox fx:id="cmbChucVu" promptText="Chức vụ" style="-fx-min-width:140px;"/>
        <Button text="Tìm" styleClass="btn-primary,btn-sm" onAction="#handleSearch"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="+ Thêm NV" styleClass="btn-success" onAction="#handleThem"/>
        <Button fx:id="btnSua" text="✏ Sửa" styleClass="btn-warning" onAction="#handleSua"/>
        <Button fx:id="btnXoa" text="✕ Xóa" styleClass="btn-danger" onAction="#handleXoa"/>
    </HBox>

    <HBox spacing="14" VBox.vgrow="ALWAYS">
        <VBox styleClass="card" HBox.hgrow="ALWAYS" spacing="0" style="-fx-padding:0;-fx-background-radius:8;">
            <Label text="Danh Sách Nhân Viên"
                   style="-fx-font-size:14px;-fx-font-weight:bold;-fx-text-fill:#1E2A3A;-fx-padding:12 16;"/>
            <TableView fx:id="tableNhanVien" VBox.vgrow="ALWAYS" onMouseClicked="#handleRowSelect">
                <columns>
                    <TableColumn fx:id="colMaNV" text="Mã NV" prefWidth="90"/>
                    <TableColumn fx:id="colHoTen" text="Họ Tên" prefWidth="160"/>
                    <TableColumn fx:id="colSdt" text="Điện Thoại" prefWidth="120"/>
                    <TableColumn fx:id="colChucVu" text="Chức Vụ" prefWidth="120"/>
                    <TableColumn fx:id="colLuong" text="Lương (đ)" prefWidth="120"/>
                    <TableColumn fx:id="colNgayVaoLam" text="Ngày Vào" prefWidth="110"/>
                    <TableColumn fx:id="colTrangThai" text="Trạng Thái" prefWidth="110"/>
                </columns>
            </TableView>
        </VBox>

        <!-- Form -->
        <VBox styleClass="card" minWidth="320" maxWidth="340" spacing="12">
            <Label fx:id="lblFormTitle" text="Thông Tin Nhân Viên"
                   style="-fx-font-size:14px;-fx-font-weight:bold;-fx-text-fill:#1E2A3A;"/>
            <Separator/>
            <GridPane hgap="8" vgap="10">
                <columnConstraints>
                    <ColumnConstraints minWidth="100"/>
                    <ColumnConstraints hgrow="ALWAYS"/>
                </columnConstraints>

                <Label text="Mã NV:" styleClass="form-label" GridPane.rowIndex="0"/>
                <TextField fx:id="txtMaNV" editable="false" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                <Label text="Họ tên *:" styleClass="form-label" GridPane.rowIndex="1"/>
                <TextField fx:id="txtHoTen" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                <Label text="Điện thoại:" styleClass="form-label" GridPane.rowIndex="2"/>
                <TextField fx:id="txtSdt" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                <Label text="Email:" styleClass="form-label" GridPane.rowIndex="3"/>
                <TextField fx:id="txtEmail" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

                <Label text="Chức vụ *:" styleClass="form-label" GridPane.rowIndex="4"/>
                <ComboBox fx:id="cmbChucVuForm" GridPane.rowIndex="4" GridPane.columnIndex="1" maxWidth="Infinity"/>

                <Label text="Lương (đ):" styleClass="form-label" GridPane.rowIndex="5"/>
                <TextField fx:id="txtLuong" GridPane.rowIndex="5" GridPane.columnIndex="1"/>

                <Label text="Ngày vào làm:" styleClass="form-label" GridPane.rowIndex="6"/>
                <DatePicker fx:id="dpNgayVaoLam" GridPane.rowIndex="6" GridPane.columnIndex="1" maxWidth="Infinity"/>

                <Label text="Username:" styleClass="form-label" GridPane.rowIndex="7"/>
                <TextField fx:id="txtUsername" GridPane.rowIndex="7" GridPane.columnIndex="1"/>

                <Label text="Mật khẩu:" styleClass="form-label" GridPane.rowIndex="8"/>
                <PasswordField fx:id="txtPassword" GridPane.rowIndex="8" GridPane.columnIndex="1"/>
            </GridPane>
            <Region VBox.vgrow="ALWAYS"/>
            <HBox spacing="8">
                <Button text="💾 Lưu" styleClass="btn-primary" maxWidth="Infinity" HBox.hgrow="ALWAYS" onAction="#handleSave"/>
                <Button text="✕ Hủy" styleClass="btn-secondary" maxWidth="Infinity" HBox.hgrow="ALWAYS" onAction="#handleCancel"/>
            </HBox>
        </VBox>
    </HBox>
</VBox>