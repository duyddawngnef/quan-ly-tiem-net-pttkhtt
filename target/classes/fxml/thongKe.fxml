<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>
<?import javafx.collections.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="gui.controller.ThongKeController"
      stylesheets="@../css/style.css"
      spacing="16" style="-fx-padding: 0;">

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="12">
        <Label text="📊" style="-fx-font-size:26px;"/>
        <VBox spacing="2">
            <Label text="Thống Kê &amp; Báo Cáo" styleClass="page-title"/>
            <Label text="Phân tích doanh thu, chi phí và lợi nhuận" styleClass="page-subtitle"/>
        </VBox>
    </HBox>

    <!-- Summary cards -->
    <HBox spacing="12">
        <VBox styleClass="stat-card stat-card-green" spacing="4" HBox.hgrow="ALWAYS">
            <Label fx:id="lblTongThu" text="0 ₫" styleClass="stat-number"
                   style="-fx-font-size:18px; -fx-text-fill:#388E3C;"/>
            <Label text="Tổng thu (Hóa đơn)" styleClass="stat-label"/>
        </VBox>
        <VBox styleClass="stat-card stat-card-red" spacing="4" HBox.hgrow="ALWAYS">
            <Label fx:id="lblTongChi" text="0 ₫" styleClass="stat-number"
                   style="-fx-font-size:18px; -fx-text-fill:#C62828;"/>
            <Label text="Tổng chi (Nhập hàng)" styleClass="stat-label"/>
        </VBox>
        <VBox styleClass="stat-card stat-card-blue" spacing="4" HBox.hgrow="ALWAYS">
            <Label fx:id="lblLoiNhuan" text="0 ₫" styleClass="stat-number"
                   style="-fx-font-size:18px; -fx-text-fill:#1565C0;"/>
            <Label text="Lợi nhuận" styleClass="stat-label"/>
        </VBox>
        <VBox styleClass="stat-card" spacing="4" HBox.hgrow="ALWAYS">
            <Label fx:id="lblSoPhien" text="0" styleClass="stat-number"/>
            <Label text="Tổng phiên" styleClass="stat-label"/>
        </VBox>
    </HBox>

    <!-- Tab panels -->
    <TabPane VBox.vgrow="ALWAYS" tabClosingPolicy="UNAVAILABLE">

        <!-- Tab 1: Doanh thu -->
        <Tab text="📈  Doanh thu">
            <VBox spacing="12" style="-fx-padding:16;">
                <!-- Filter bar -->
                <HBox spacing="10" alignment="CENTER_LEFT" styleClass="toolbar">
                    <Label text="Loại:" style="-fx-text-fill:#555555;"/>
                    <ComboBox fx:id="cboLoaiTK" styleClass="combo-box" prefWidth="160"
                              onAction="#handleLoaiTKChanged">
                    </ComboBox>
                    <DatePicker fx:id="dateFrom" promptText="Từ ngày" prefWidth="130"/>
                    <DatePicker fx:id="dateTo" promptText="Đến ngày" prefWidth="130"/>
                    <Button text="📊  Thống kê" styleClass="btn btn-primary"
                            onAction="#handleThongKe"/>
                    <Pane HBox.hgrow="ALWAYS"/>
                    <Button text="📊  Xuất Excel" styleClass="btn btn-success"
                            onAction="#handleXuatExcel"/>
                </HBox>

                <SplitPane dividerPositions="0.5" VBox.vgrow="ALWAYS">
                    <!-- Table -->
                    <VBox styleClass="page-card" spacing="0" style="-fx-padding:0;">
                        <Label text="Bảng dữ liệu"
                               style="-fx-padding:12 16; -fx-font-weight:bold; -fx-text-fill:#1565C0;"/>
                        <TableView fx:id="tableThongKe" VBox.vgrow="ALWAYS">
                            <TableColumn fx:id="colTKNhom" text="Nhóm" prefWidth="200"/>
                            <TableColumn fx:id="colTKQ1" text="Q1" prefWidth="90"/>
                            <TableColumn fx:id="colTKQ2" text="Q2" prefWidth="90"/>
                            <TableColumn fx:id="colTKQ3" text="Q3" prefWidth="90"/>
                            <TableColumn fx:id="colTKQ4" text="Q4" prefWidth="90"/>
                            <TableColumn fx:id="colTKTC" text="Tổng cộng" prefWidth="110"/>
                        </TableView>
                    </VBox>

                    <!-- Chart placeholder -->
                    <VBox styleClass="page-card" alignment="CENTER" spacing="10">
                        <Label text="📊" style="-fx-font-size:48px;"/>
                        <Label fx:id="lblChartPlaceholder"
                               text="Nhấn 'Thống kê' để hiển thị biểu đồ"
                               style="-fx-text-fill:#AAAAAA; -fx-font-size:14px;"/>
                        <StackPane fx:id="chartContainer" VBox.vgrow="ALWAYS" maxWidth="Infinity"/>
                    </VBox>
                </SplitPane>
            </VBox>
        </Tab>

        <!-- Tab 2: Thu Chi Loi Nhuan -->
        <Tab text="💰  Thu - Chi - Lợi nhuận">
            <VBox spacing="12" style="-fx-padding:16;">
                <HBox spacing="10" alignment="CENTER_LEFT" styleClass="toolbar">
                    <Label text="Khoảng thời gian:" style="-fx-text-fill:#555555;"/>
                    <ComboBox fx:id="cboThoiGian" styleClass="combo-box" prefWidth="160">
                    </ComboBox>
                    <DatePicker fx:id="dateTCFrom" promptText="Từ ngày" prefWidth="130"/>
                    <DatePicker fx:id="dateTCTo" promptText="Đến ngày" prefWidth="130"/>
                    <Button text="📊  Xem" styleClass="btn btn-primary" onAction="#handleThongKeThuChi"/>
                </HBox>

                <TableView fx:id="tableThuChi" VBox.vgrow="ALWAYS" styleClass="page-card" style="-fx-padding:0;">
                    <TableColumn fx:id="colTCThang" text="Tháng/Kỳ" prefWidth="150"/>
                    <TableColumn fx:id="colTCThu" text="Tổng thu (₫)" prefWidth="160"/>
                    <TableColumn fx:id="colTCChi" text="Tổng chi (₫)" prefWidth="160"/>
                    <TableColumn fx:id="colTCLoiNhuan" text="Lợi nhuận (₫)" prefWidth="160"/>
                    <TableColumn fx:id="colTCTyLe" text="Tỷ lệ (%)" prefWidth="110"/>
                </TableView>
            </VBox>
        </Tab>

        <!-- Tab 3: Top KH / NV -->
        <Tab text="🏆  Top khách hàng">
            <VBox spacing="12" style="-fx-padding:16;">
                <HBox spacing="10" alignment="CENTER_LEFT" styleClass="toolbar">
                    <Label text="Năm:" style="-fx-text-fill:#555555;"/>
                    <ComboBox fx:id="cboNamTop" styleClass="combo-box" prefWidth="100"/>
                    <Label text="Hiển thị top:" style="-fx-text-fill:#555555;"/>
                    <ComboBox fx:id="cboTopN" styleClass="combo-box" prefWidth="100">
                    </ComboBox>
                    <Button text="📊  Xem" styleClass="btn btn-primary" onAction="#handleThongKeTop"/>
                </HBox>
                <TableView fx:id="tableTop" VBox.vgrow="ALWAYS" styleClass="page-card" style="-fx-padding:0;">
                    <TableColumn fx:id="colTopSTT" text="STT" prefWidth="60"/>
                    <TableColumn fx:id="colTopTen" text="Khách hàng" prefWidth="200"/>
                    <TableColumn fx:id="colTopSoPhien" text="Số phiên" prefWidth="100"/>
                    <TableColumn fx:id="colTopThoiGian" text="Tổng giờ" prefWidth="110"/>
                    <TableColumn fx:id="colTopTongTien" text="Tổng chi tiêu (₫)" prefWidth="160"/>
                </TableView>
            </VBox>
        </Tab>

    </TabPane>

</VBox>
