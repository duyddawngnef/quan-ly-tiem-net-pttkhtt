<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="gui.dialog.ThemNhanVienDialog"
      stylesheets="@../../css/style.css"
      spacing="0" style="-fx-min-width:460; -fx-max-width:520;">

    <!-- Header -->
    <HBox styleClass="dialog-header" spacing="12" alignment="CENTER_LEFT">
        <Label text="🏢" style="-fx-font-size:22px;"/>
        <Label fx:id="lblDialogTitle" text="Thêm / Sửa Nhân Viên" styleClass="dialog-title"/>
    </HBox>

    <!-- Body -->
    <ScrollPane fitToWidth="true" style="-fx-background-color:transparent; -fx-border-color:transparent; -fx-max-height:480;">
        <VBox styleClass="dialog-body" spacing="12">
            <VBox spacing="4">
                <Label text="Họ *" styleClass="form-label"/>
                <TextField fx:id="txtHo" promptText="Nhập họ" styleClass="text-field" maxWidth="Infinity"/>
                <Label fx:id="lbltxtHoError" styleClass="error-label" text=""/>
            </VBox>
            <VBox spacing="4">
                <Label text="Tên *" styleClass="form-label"/>
                <TextField fx:id="txtTen" promptText="Nhập tên" styleClass="text-field" maxWidth="Infinity"/>
                <Label fx:id="lbltxtTenError" styleClass="error-label" text=""/>
            </VBox>
            <VBox spacing="4">
                <Label text="Số điện thoại *" styleClass="form-label"/>
                <TextField fx:id="txtSDT" promptText="VD: 0912345678" styleClass="text-field" maxWidth="Infinity"/>
                <Label fx:id="lbltxtSDTError" styleClass="error-label" text=""/>
            </VBox>
            <VBox spacing="4">
                <Label text="Tên đăng nhập *" styleClass="form-label"/>
                <TextField fx:id="txtTenDangNhap" promptText="Tối thiểu 6 ký tự" styleClass="text-field" maxWidth="Infinity"/>
                <Label fx:id="lbltxtTenDangNhapError" styleClass="error-label" text=""/>
            </VBox>
            <VBox spacing="4">
                <Label text="Mật khẩu *" styleClass="form-label"/>
                <PasswordField fx:id="txtMatKhau" promptText="Tối thiểu 6 ký tự" styleClass="text-field" maxWidth="Infinity"/>
                <Label fx:id="lbltxtMatKhauError" styleClass="error-label" text=""/>
            </VBox>
            <VBox spacing="4">
                <Label text="Chức vụ *" styleClass="form-label"/>
                <ComboBox fx:id="cboChucVu" promptText="Chọn chức vụ" styleClass="combo-box" maxWidth="Infinity"/>
                <Label fx:id="lblcboChucVuError" styleClass="error-label" text=""/>
            </VBox>
            <VBox spacing="4">
                <Label text="Ngày vào làm" styleClass="form-label"/>
                <DatePicker fx:id="datNgayVaoLam" promptText="Chọn ngày" maxWidth="Infinity"/>
                <Label fx:id="lbldatNgayVaoLamError" styleClass="error-label" text=""/>
            </VBox>

            <Label fx:id="lblError" styleClass="error-label" text="" wrapText="true"/>
        </VBox>
    </ScrollPane>

    <!-- Footer -->
    <HBox styleClass="dialog-footer" spacing="10" alignment="CENTER_RIGHT">
        <Button text="✕  Hủy" styleClass="btn btn-secondary"
                onAction="#handleCancel"/>
        <Button fx:id="btnSave" text="💾  Lưu" styleClass="btn btn-primary"
                onAction="#handleSave"/>
    </HBox>

</VBox>
