<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="gui.dialog.ThemDichVuDialog"
      stylesheets="@../../css/style.css"
      spacing="0" style="-fx-min-width:460; -fx-max-width:520;">

    <!-- Header -->
    <HBox styleClass="dialog-header" spacing="12" alignment="CENTER_LEFT">
        <Label text="🥤" style="-fx-font-size:22px;"/>
        <Label fx:id="lblDialogTitle" text="Thêm / Sửa Dịch Vụ" styleClass="dialog-title"/>
    </HBox>

    <!-- Body -->
    <ScrollPane fitToWidth="true" style="-fx-background-color:transparent; -fx-border-color:transparent; -fx-max-height:480;">
        <VBox styleClass="dialog-body" spacing="12">
            <VBox spacing="4">
                <Label text="Mã dịch vụ *" styleClass="form-label"/>
                <TextField fx:id="txtMaDV" promptText="VD: DV001" styleClass="text-field" maxWidth="Infinity"/>
                <Label fx:id="lbltxtMaDVError" styleClass="error-label" text=""/>
            </VBox>
            <VBox spacing="4">
                <Label text="Tên dịch vụ *" styleClass="form-label"/>
                <TextField fx:id="txtTenDV" promptText="VD: Nước ngọt" styleClass="text-field" maxWidth="Infinity"/>
                <Label fx:id="lbltxtTenDVError" styleClass="error-label" text=""/>
            </VBox>
            <VBox spacing="4">
                <Label text="Đơn giá (VNĐ) *" styleClass="form-label"/>
                <TextField fx:id="txtGia" promptText="VD: 15000" styleClass="text-field" maxWidth="Infinity"/>
                <Label fx:id="lbltxtGiaError" styleClass="error-label" text=""/>
            </VBox>
            <VBox spacing="4">
                <Label text="Đơn vị tính *" styleClass="form-label"/>
                <TextField fx:id="txtDonVi" promptText="VD: Lon, Gói, Ly" styleClass="text-field" maxWidth="Infinity"/>
                <Label fx:id="lbltxtDonViError" styleClass="error-label" text=""/>
            </VBox>
            <VBox spacing="4">
                <Label text="Tồn kho ban đầu" styleClass="form-label"/>
                <TextField fx:id="txtTonKho" promptText="VD: 100" styleClass="text-field" maxWidth="Infinity"/>
                <Label fx:id="lbltxtTonKhoError" styleClass="error-label" text=""/>
            </VBox>
            <VBox spacing="4">
                <Label text="Trạng thái" styleClass="form-label"/>
                <ComboBox fx:id="cboTrangThai" promptText="Chọn trạng thái" styleClass="combo-box" maxWidth="Infinity"/>
                <Label fx:id="lblcboTrangThaiError" styleClass="error-label" text=""/>
            </VBox>
            <VBox spacing="4">
                <Label text="Mô tả" styleClass="form-label"/>
                <TextArea fx:id="txtMoTa" promptText="Mô tả thêm..." styleClass="text-field" maxWidth="Infinity" prefRowCount="3" wrapText="true"/>
                <Label fx:id="lbltxtMoTaError" styleClass="error-label" text=""/>
            </VBox>

            <Label fx:id="lblError" styleClass="error-label" text="" wrapText="true"/>
        </VBox>
    </ScrollPane>

    <!-- Footer -->
    <HBox styleClass="dialog-footer" spacing="10" alignment="CENTER_RIGHT">
        <Button text="✕  Hủy" styleClass="btn btn-secondary"
                onAction="#handleCancel"/>
        <Button fx:id="btnSave" text="💾  Lưu" styleClass="btn btn-primary"
                onAction="#handleSave"/>
    </HBox>

</VBox>
