<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>
<?import javafx.collections.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="gui.controller.KhachHangController"
      stylesheets="@../css/style.css"
      spacing="16" styleClass="no-padding">

    <!-- Page Header -->
    <HBox alignment="CENTER_LEFT" spacing="12"
          styleClass="page-header-padding">
        <Label text="&#xf233;" styleClass="page-icon, icon-lg"/>
        <VBox spacing="2">
            <Label text="Quản Lý Khách Hàng" styleClass="page-title"/>
            <Label fx:id="lblSubtitle" text="Đang tải..." styleClass="page-subtitle"/>
        </VBox>
    </HBox>

    <!-- Toolbar -->
    <HBox styleClass="toolbar" spacing="8" alignment="CENTER_LEFT">
        <TextField fx:id="txtSearch" promptText="  Tìm kiếm..." styleClass="search-bar"
                   prefWidth="260" onKeyReleased="#handleSearch"/>
                <ComboBox fx:id="cboTrangThai" promptText="Trạng thái" styleClass="combo-box" prefWidth="140">
                </ComboBox>
                <ComboBox fx:id="cbFilterSoDu" promptText="Tất cả số dư" styleClass="combo-box" prefWidth="180" >
                </ComboBox>
        <Pane HBox.hgrow="ALWAYS"/>
        <Button fx:id="btnThem" styleClass="btn btn-primary"
                onAction="#handleThem">
            <graphic><Label text="&#xe145;" styleClass="icon-sm"/></graphic>
            <text>  Thêm</text>
        </Button>
        <Button fx:id="btnSua" styleClass="btn btn-warning"
                onAction="#handleSua" disable="true">
            <graphic><Label text="&#xe3c9;" styleClass="icon-sm"/></graphic>
            <text>  Sửa</text>
        </Button>
        <Button fx:id="btnXoa" styleClass="btn btn-danger"
                onAction="#handleXoa" disable="true">
            <graphic><Label text="&#xe872;" styleClass="icon-sm"/></graphic>
            <text>  Xóa</text>
        </Button>
        <Button fx:id="btnLamMoi" styleClass="btn btn-secondary"
                onAction="#handleLamMoi">
            <graphic><Label text="&#xe5d5;" styleClass="icon-sm"/></graphic>
            <text>  Làm mới</text>
        </Button>

        <Button styleClass="btn btn-success" onAction="#exportExcel">
            <graphic><Label text="&#xeb9e;" styleClass="icon-sm"/></graphic>
            <text>  Xuất Excel</text>
        </Button>
    </HBox>

    <!-- Table -->
    <VBox VBox.vgrow="ALWAYS" styleClass="page-card, no-padding" spacing="0">
        <TableView fx:id="tableView" VBox.vgrow="ALWAYS"
                   styleClass="table-rounded">
            <columns>
                <TableColumn fx:id="colMaKH" text="Mã KH" prefWidth="100"/>
                <TableColumn fx:id="colHoTen" text="Họ tên" prefWidth="250"/>
                <TableColumn fx:id="colSDT" text="Điện thoại" prefWidth="150"/>
                <TableColumn fx:id="colSoDu" text="Số dư (VNĐ)" prefWidth="150"/>
                <TableColumn fx:id="colTrangThai" text="Trạng thái" prefWidth="150"/>
            </columns>
        </TableView>

        <HBox alignment="CENTER_RIGHT" spacing="12" styleClass="table-footer">
            <Label fx:id="lblTotal" text="Tổng: 0 bản ghi" styleClass="page-subtitle"/>
        </HBox>
    </VBox>

</VBox>
