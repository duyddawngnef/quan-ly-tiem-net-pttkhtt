<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="gui.controller.PhienSuDungController"
      spacing="14" style="-fx-padding:20;">

    <!-- Toolbar -->
    <HBox styleClass="card" alignment="CENTER_LEFT" spacing="12"
          style="-fx-padding:12 16;-fx-background-radius:8;">
        <TextField fx:id="txtSearch" styleClass="search-field"
                   promptText="🔍 Tìm theo mã KH, máy..."/>
        <ComboBox fx:id="cmbTrangThai" promptText="Trạng thái"
                  style="-fx-min-width:150px;"/>
        <DatePicker fx:id="dpTu" promptText="Từ ngày"/>
        <DatePicker fx:id="dpDen" promptText="Đến ngày"/>
        <Button text="Tìm" styleClass="btn-primary,btn-sm" onAction="#handleSearch"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="btnMoPhien" text="▶ Mở Phiên" styleClass="btn-success" onAction="#handleMoPhien"/>
        <Button fx:id="btnKetThuc" text="⏹ Kết Thúc" styleClass="btn-danger" onAction="#handleKetThucPhien"/>
    </HBox>

    <!-- Main: table + detail side by side -->
    <HBox spacing="14" VBox.vgrow="ALWAYS">

        <!-- Table -->
        <VBox styleClass="card" HBox.hgrow="ALWAYS" spacing="0"
              style="-fx-padding:0;-fx-background-radius:8;">
            <Label text="Danh Sách Phiên Sử Dụng" style="-fx-font-size:14px;-fx-font-weight:bold;-fx-text-fill:#1E2A3A;-fx-padding:14 16 10 16;"/>
            <TableView fx:id="tablePhien" VBox.vgrow="ALWAYS"
                       style="-fx-background-radius:0 0 8 8;" onMouseClicked="#handleTableClick">
                <columns>
                    <TableColumn fx:id="colMaPhien" text="Mã Phiên" prefWidth="90"/>
                    <TableColumn fx:id="colMaMay" text="Máy" prefWidth="80"/>
                    <TableColumn fx:id="colKhachHang" text="Khách Hàng" prefWidth="150"/>
                    <TableColumn fx:id="colGioBatDau" text="Giờ Bắt Đầu" prefWidth="140"/>
                    <TableColumn fx:id="colGioKetThuc" text="Giờ Kết Thúc" prefWidth="140"/>
                    <TableColumn fx:id="colThoiGian" text="Thời Gian" prefWidth="100"/>
                    <TableColumn fx:id="colTienPhi" text="Tiền Phí" prefWidth="110"/>
                    <TableColumn fx:id="colTrangThai" text="Trạng Thái" prefWidth="110"/>
                </columns>
            </TableView>
        </VBox>

        <!-- Detail panel -->
        <VBox styleClass="card" minWidth="280" maxWidth="300" spacing="14">
            <Label text="Chi Tiết Phiên" style="-fx-font-size:14px;-fx-font-weight:bold;-fx-text-fill:#1E2A3A;"/>
            <Separator/>

            <GridPane hgap="8" vgap="10">
                <columnConstraints>
                    <ColumnConstraints minWidth="90"/>
                    <ColumnConstraints hgrow="ALWAYS"/>
                </columnConstraints>

                <Label text="Mã phiên:" styleClass="form-label" GridPane.rowIndex="0"/>
                <Label fx:id="lblMaPhien" text="---" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                <Label text="Máy:" styleClass="form-label" GridPane.rowIndex="1"/>
                <Label fx:id="lblMaMay" text="---" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                <Label text="Khách hàng:" styleClass="form-label" GridPane.rowIndex="2"/>
                <Label fx:id="lblKhachHang" text="---" GridPane.rowIndex="2" GridPane.columnIndex="1" wrapText="true"/>

                <Label text="Số dư KH:" styleClass="form-label" GridPane.rowIndex="3"/>
                <Label fx:id="lblSoDu" text="0 đ" GridPane.rowIndex="3" GridPane.columnIndex="1"
                       style="-fx-text-fill:#43A047;-fx-font-weight:bold;"/>

                <Label text="Bắt đầu:" styleClass="form-label" GridPane.rowIndex="4"/>
                <Label fx:id="lblGioBatDau" text="---" GridPane.rowIndex="4" GridPane.columnIndex="1"/>

                <Label text="Đã chạy:" styleClass="form-label" GridPane.rowIndex="5"/>
                <Label fx:id="lblThoiGian" text="0 phút" GridPane.rowIndex="5" GridPane.columnIndex="1"
                       style="-fx-text-fill:#1A73E8;-fx-font-weight:bold;"/>

                <Label text="Tiền phí:" styleClass="form-label" GridPane.rowIndex="6"/>
                <Label fx:id="lblTienPhi" text="0 đ" GridPane.rowIndex="6" GridPane.columnIndex="1"
                       style="-fx-text-fill:#E53935;-fx-font-size:14px;-fx-font-weight:bold;"/>

                <Label text="Trạng thái:" styleClass="form-label" GridPane.rowIndex="7"/>
                <Label fx:id="lblTrangThai" text="---" GridPane.rowIndex="7" GridPane.columnIndex="1"/>
            </GridPane>

            <Region VBox.vgrow="ALWAYS"/>

            <VBox spacing="8">
                <Button text="▶ Mở Phiên Mới" styleClass="btn-success" maxWidth="Infinity" onAction="#handleMoPhien"/>
                <Button text="⏹ Kết Thúc &amp; Tính Tiền" styleClass="btn-danger" maxWidth="Infinity" onAction="#handleKetThucPhien"/>
                <Button text="🔄 Làm Mới" styleClass="btn-secondary" maxWidth="Infinity" onAction="#handleRefresh"/>
            </VBox>
        </VBox>
    </HBox>
</VBox>