<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="gui.controller.PhienSuDungController"
      stylesheets="@../css/style.css"
      spacing="16" styleClass="no-padding">

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="12">
        <Label text="&#xe425;" styleClass="page-icon, icon-lg"/>
        <VBox spacing="2">
            <Label text="Quản Lý Phiên Sử Dụng" styleClass="page-title"/>
            <Label fx:id="lblSubtitle" text="Đang tải..." styleClass="page-subtitle"/>
        </VBox>
        <Pane HBox.hgrow="ALWAYS"/>
        <HBox spacing="4" alignment="CENTER_RIGHT">
            <Label text="&#xe8b5;" styleClass="icon-sm"/>
            <Label fx:id="lblLiveTime" text="00:00:00" styleClass="live-time"/>
        </HBox>
    </HBox>

    <!-- Stats Cards -->
    <HBox spacing="12">
        <VBox styleClass="stat-card stat-card-blue" spacing="4" HBox.hgrow="ALWAYS">
            <Label fx:id="lblDangChoi" text="0" styleClass="stat-number, stat-number-blue"/>
            <Label text="Phiên đang chơi" styleClass="stat-label"/>
        </VBox>
        <VBox styleClass="stat-card stat-card-green" spacing="4" HBox.hgrow="ALWAYS">
            <Label fx:id="lblDoanhThuNgay" text="0 ₫" styleClass="stat-number, stat-number-green, stat-number-small"/>
            <Label text="Doanh thu hôm nay" styleClass="stat-label"/>
        </VBox>
        <VBox styleClass="stat-card" spacing="4" HBox.hgrow="ALWAYS">
            <Label fx:id="lblPhienHomNay" text="0" styleClass="stat-number"/>
            <Label text="Phiên hôm nay" styleClass="stat-label"/>
        </VBox>
    </HBox>

    <!-- Toolbar -->
    <HBox styleClass="toolbar" spacing="8" alignment="CENTER_LEFT">
        <TextField fx:id="txtSearch" promptText="  Tìm KH, máy, mã phiên..."
                   styleClass="search-bar" prefWidth="240" onKeyReleased="#handleSearch"/>
        <ComboBox fx:id="cboTrangThai" prefWidth="160" onAction="#handleFilter"/>
        <Pane HBox.hgrow="ALWAYS"/>
        <Button styleClass="btn btn-success" onAction="#handleMoPhien">
            <graphic><Label text="&#xe037;" styleClass="icon-sm"/></graphic>
            <text>  Mở phiên mới</text>
        </Button>
        <Button fx:id="btnKetThuc" styleClass="btn btn-danger"
                onAction="#handleKetThucPhien" disable="true">
            <graphic><Label text="&#xe047;" styleClass="icon-sm"/></graphic>
            <text>  Kết thúc</text>
        </Button>
        <Button fx:id="btnOrderDV" styleClass="btn btn-warning"
                onAction="#handleOrderDichVu" disable="true">
            <graphic><Label text="&#xe63d;" styleClass="icon-sm"/></graphic>
            <text>  Order DV</text>
        </Button>
        <Button text="&#xe5d5;" styleClass="btn btn-secondary, refresh-btn-large, icon" onAction="#handleRefresh"/>
    </HBox>

    <!-- Table -->
    <VBox VBox.vgrow="ALWAYS" styleClass="page-card, no-padding" spacing="0">
        <TableView fx:id="tableView" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colMaPhien"   text="Mã phiên"       prefWidth="110"/>
                <TableColumn fx:id="colMaMay"     text="Máy"            prefWidth="90"/>
                <TableColumn fx:id="colKhachHang" text="Khách hàng"     prefWidth="120"/>
                <TableColumn fx:id="colNhanVien"  text="NV mở"          prefWidth="110"/>
                <TableColumn fx:id="colGioBD"     text="Giờ bắt đầu"   prefWidth="130"/>
                <TableColumn fx:id="colThoiGian"  text="Thời gian"      prefWidth="100"/>
                <TableColumn fx:id="colTienTam"   text="Tiền tạm (₫)"  prefWidth="130"/>
                <TableColumn fx:id="colTrangThai" text="Trạng thái"     prefWidth="130"/>
            </columns>
        </TableView>

        <HBox alignment="CENTER_RIGHT" spacing="12" styleClass="table-footer">
            <Label fx:id="lblTotal" text="Tổng: 0 phiên" styleClass="page-subtitle"/>
        </HBox>
    </VBox>

</VBox>
