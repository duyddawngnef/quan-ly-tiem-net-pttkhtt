<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="gui.controller.NapTienController"
      spacing="16" style="-fx-padding:20;">

    <!-- Nạp tiền card -->
    <HBox spacing="16" VBox.vgrow="ALWAYS">

        <!-- Form nạp tiền -->
        <VBox styleClass="card" minWidth="400" spacing="16">
            <Label text="💰 Nạp Tiền Tài Khoản" style="-fx-font-size:16px;-fx-font-weight:bold;-fx-text-fill:#1E2A3A;"/>
            <Separator/>

            <!-- Tìm khách hàng -->
            <VBox spacing="6">
                <Label text="Tìm Khách Hàng" styleClass="form-label"/>
                <HBox spacing="8">
                    <TextField fx:id="txtTimKH" styleClass="search-field" promptText="Nhập mã KH hoặc SĐT..."
                               HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                    <Button text="Tìm" styleClass="btn-primary" onAction="#handleTimKH"/>
                    <Button text="..." styleClass="btn-secondary" onAction="#handleChonKH"
                            tooltip="Chọn khách hàng từ danh sách"/>
                </HBox>
            </VBox>

            <!-- Thông tin KH (hiện sau khi tìm) -->
            <VBox fx:id="infoKHPane" styleClass="card" spacing="10"
                  style="-fx-background-color:#F0F7FF;-fx-border-color:#90CAF9;-fx-border-width:1;-fx-border-radius:6;-fx-background-radius:6;"
                  managed="false" visible="false">
                <Label text="Thông Tin Khách Hàng" styleClass="form-label"/>
                <GridPane hgap="12" vgap="8">
                    <columnConstraints>
                        <ColumnConstraints minWidth="100"/>
                        <ColumnConstraints hgrow="ALWAYS"/>
                        <ColumnConstraints minWidth="100"/>
                        <ColumnConstraints hgrow="ALWAYS"/>
                    </columnConstraints>
                    <Label text="Mã KH:" styleClass="form-label" GridPane.rowIndex="0"/>
                    <Label fx:id="lblMaKH" text="---" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                    <Label text="Họ tên:" styleClass="form-label" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
                    <Label fx:id="lblHoTen" text="---" GridPane.rowIndex="0" GridPane.columnIndex="3"/>
                    <Label text="Số dư hiện tại:" styleClass="form-label" GridPane.rowIndex="1"/>
                    <Label fx:id="lblSoDu" text="0 đ" GridPane.rowIndex="1" GridPane.columnIndex="1"
                           style="-fx-font-size:15px;-fx-font-weight:bold;-fx-text-fill:#1A73E8;"/>
                    <Label text="Điểm thưởng:" styleClass="form-label" GridPane.rowIndex="1" GridPane.columnIndex="2"/>
                    <Label fx:id="lblDiem" text="0 điểm" GridPane.rowIndex="1" GridPane.columnIndex="3"/>
                </GridPane>
            </VBox>

            <!-- Số tiền nạp -->
            <VBox spacing="6">
                <Label text="Số Tiền Nạp (đ) *" styleClass="form-label"/>
                <TextField fx:id="txtSoTienNap" promptText="Nhập số tiền..."/>
            </VBox>

            <!-- Quick amount -->
            <VBox spacing="6">
                <Label text="Chọn Nhanh" styleClass="form-label"/>
                <HBox spacing="8">
                    <Button text="50.000đ" styleClass="btn-secondary,btn-sm" onAction="#handleQuickAmount" userData="50000"/>
                    <Button text="100.000đ" styleClass="btn-secondary,btn-sm" onAction="#handleQuickAmount" userData="100000"/>
                    <Button text="200.000đ" styleClass="btn-secondary,btn-sm" onAction="#handleQuickAmount" userData="200000"/>
                    <Button text="500.000đ" styleClass="btn-secondary,btn-sm" onAction="#handleQuickAmount" userData="500000"/>
                </HBox>
            </VBox>

            <!-- Ghi chú -->
            <VBox spacing="6">
                <Label text="Ghi Chú" styleClass="form-label"/>
                <TextField fx:id="txtGhiChu" promptText="Ghi chú giao dịch..."/>
            </VBox>

            <!-- Nhân viên thu -->
            <VBox spacing="6">
                <Label text="Nhân Viên Thu" styleClass="form-label"/>
                <TextField fx:id="txtNhanVien" editable="false"
                           style="-fx-background-color:#F5F6FA;"/>
            </VBox>

            <Label fx:id="lblError" style="-fx-text-fill:#E53935;-fx-font-weight:bold;" text="" wrapText="true"/>

            <Button text="💰 XÁC NHẬN NẠP TIỀN" styleClass="btn-success"
                    maxWidth="Infinity" onAction="#handleNapTien"
                    style="-fx-pref-height:42px;-fx-font-size:14px;"/>
        </VBox>

        <!-- Lịch sử nạp tiền -->
        <VBox styleClass="card" HBox.hgrow="ALWAYS" spacing="0" style="-fx-padding:0;-fx-background-radius:8;">
            <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding:12 16;">
                <Label text="Lịch Sử Nạp Tiền"
                       style="-fx-font-size:14px;-fx-font-weight:bold;-fx-text-fill:#1E2A3A;" HBox.hgrow="ALWAYS"/>
                <DatePicker fx:id="dpFilter" promptText="Lọc theo ngày"/>
                <Button text="Lọc" styleClass="btn-primary,btn-sm" onAction="#handleFilter"/>
            </HBox>
            <TableView fx:id="tableLichSu" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colMaNap" text="Mã GD" prefWidth="90"/>
                    <TableColumn fx:id="colMaKH" text="Khách Hàng" prefWidth="150"/>
                    <TableColumn fx:id="colSoTien" text="Số Tiền (đ)" prefWidth="130"/>
                    <TableColumn fx:id="colNgayNap" text="Ngày Nạp" prefWidth="150"/>
                    <TableColumn fx:id="colNhanVien" text="Nhân Viên" prefWidth="130"/>
                    <TableColumn fx:id="colGhiChu" text="Ghi Chú" prefWidth="200"/>
                </columns>
            </TableView>
        </VBox>
    </HBox>
</VBox>