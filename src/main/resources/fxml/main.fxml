<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="gui.controller.MainController"
            stylesheets="@../css/style.css"
            prefWidth="1280" prefHeight="760"
            styleClass="content-wrapper">

    <!-- ===== SIDEBAR ===== -->
    <left>
        <VBox styleClass="sidebar" spacing="0" focusTraversable="false">

            <!-- Logo -->
            <VBox styleClass="sidebar-logo-area" spacing="4" focusTraversable="false">
                <HBox spacing="10" alignment="CENTER_LEFT" focusTraversable="false">
                    <Label text="🖥" focusTraversable="false"
                           styleClass="sidebar-logo-icon-label"/>
                    <VBox spacing="2" focusTraversable="false">
                        <Label text="TIỆM NET" styleClass="sidebar-logo-text" focusTraversable="false"/>
                        <Label text="Quản lý hệ thống" styleClass="sidebar-logo-sub" focusTraversable="false"/>
                    </VBox>
                </HBox>
            </VBox>

            <!-- User info strip -->
            <HBox spacing="10" alignment="CENTER_LEFT" focusTraversable="false"
                  styleClass="sidebar-user-strip">
                <StackPane styleClass="header-avatar" focusTraversable="false">
                    <Label fx:id="lblAvatarChar" text="A" focusTraversable="false"
                           styleClass="sidebar-avatar-label"/>
                </StackPane>
                <VBox spacing="2" focusTraversable="false">
                    <Label fx:id="lblUserName" text="Tên người dùng" focusTraversable="false"
                           styleClass="sidebar-user-name"/>
                    <Label fx:id="lblUserRole" text="Vai trò" focusTraversable="false"
                           styleClass="sidebar-user-role"/>
                </VBox>
            </HBox>

            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                        focusTraversable="false">
                <VBox spacing="2" focusTraversable="false"
                      styleClass="sidebar-scroll-content">

                    <!-- DASHBOARD -->
                    <Label text="TỔNG QUAN" styleClass="sidebar-section-label" focusTraversable="false"/>
                    <Button fx:id="btnSoDoMay" text="🗺  Sơ đồ máy"
                            styleClass="menu-button" onAction="#loadSoDoMay"/>

                    <!-- VẬN HÀNH -->
                    <Label text="VẬN HÀNH" styleClass="sidebar-section-label" focusTraversable="false"/>
                    <Button fx:id="btnPhienSuDung" text="⏱  Phiên sử dụng"
                            styleClass="menu-button" onAction="#loadPhienSuDung"/>
                    <Button fx:id="btnNapTien" text="💳  Nạp tiền"
                            styleClass="menu-button" onAction="#loadNapTien"/>
                    <Button fx:id="btnHoaDon" text="🧾  Hóa đơn"
                            styleClass="menu-button" onAction="#loadHoaDon"/>

                    <!-- DỊCH VỤ -->
                    <Label text="DỊCH VỤ" styleClass="sidebar-section-label" focusTraversable="false"/>
                    <Button fx:id="btnDichVu" text="🥤  Dịch vụ"
                            styleClass="menu-button" onAction="#loadDichVu"/>
                    <Button fx:id="btnGoiDichVu" text="📦  Gói dịch vụ"
                            styleClass="menu-button" onAction="#loadGoiDichVu"/>
                    <Button fx:id="btnGoiDichVuKH" text="🎫  Gói DV khách hàng"
                            styleClass="menu-button" onAction="#loadGoiDichVuKH"/>
                    <Button fx:id="btnKhuyenMai" text="🎁  Khuyến mãi"
                            styleClass="menu-button" onAction="#loadKhuyenMai"/>
                    <Button fx:id="btnNhapHang" text="📥  Nhập hàng"
                            styleClass="menu-button" onAction="#loadNhapHang"/>

                    <!-- QUẢN LÝ -->
                    <Label text="QUẢN LÝ" styleClass="sidebar-section-label" focusTraversable="false"/>
                    <Button fx:id="btnKhachHang" text="👥  Khách hàng"
                            styleClass="menu-button" onAction="#loadKhachHang"/>
                    <Button fx:id="btnNhanVien" text="🏢  Nhân viên"
                            styleClass="menu-button" onAction="#loadNhanVien"/>
                    <Button fx:id="btnMayTinh" text="💻  Máy tính"
                            styleClass="menu-button" onAction="#loadMayTinh"/>
                    <Button fx:id="btnKhuMay" text="🗂  Khu máy"
                            styleClass="menu-button" onAction="#loadKhuMay"/>

                    <!-- BÁO CÁO -->
                    <Label text="BÁO CÁO" styleClass="sidebar-section-label" focusTraversable="false"/>
                    <Button fx:id="btnThongKe" text="📊  Thống kê"
                            styleClass="menu-button" onAction="#loadThongKe"/>

                </VBox>
            </ScrollPane>

            <!-- Logout button -->
            <VBox focusTraversable="false"
                  styleClass="sidebar-logout-area">
                <Separator focusTraversable="false"
                           styleClass="sidebar-logout-separator"/>
                <Button text="🔓  Đăng xuất" styleClass="menu-button, logout-button"
                        onAction="#handleLogout"/>
            </VBox>

        </VBox>
    </left>

    <!-- ===== CONTENT AREA ===== -->
    <center>
        <VBox spacing="0" styleClass="content-wrapper">
            <!-- Header bar -->
            <HBox styleClass="header-bar" alignment="CENTER_LEFT" spacing="14">
                <Label fx:id="lblPageTitle" text="Sơ đồ máy" styleClass="header-title"
                       HBox.hgrow="ALWAYS"/>
                <Label fx:id="lblCurrentTime" text="00:00:00"
                       styleClass="header-time"/>
            </HBox>

            <!-- Dynamic content -->
            <StackPane fx:id="contentPane" VBox.vgrow="ALWAYS"
                       styleClass="content-area"/>
        </VBox>
    </center>

</BorderPane>
