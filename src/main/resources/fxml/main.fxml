<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
    fx:controller="gui.controller.MainController"
    stylesheets="@../css/style.css,@../css/button.css,@../css/table.css"
    prefWidth="1280" prefHeight="800">

    <!-- ====== SIDEBAR LEFT ====== -->
    <left>
        <VBox styleClass="sidebar" spacing="0">

            <!-- Logo Area -->
            <VBox styleClass="sidebar-logo-area" spacing="3">
                <Label text="🖥 NetManager" styleClass="sidebar-logo-text" />
                <Label text="Quản Lý Tiệm Net" styleClass="sidebar-logo-sub" />
            </VBox>

            <!-- User info -->
            <VBox
                style="-fx-padding:14 15 10 18; -fx-border-color:#2C3E50; -fx-border-width:0 0 1 0;">
                <Label fx:id="lblUserName" text="Nhân Viên"
                    style="-fx-text-fill:#ECEFF1;-fx-font-weight:bold;-fx-font-size:13px;" />
                <Label fx:id="lblUserRole" text="QUANLY" styleClass="user-role-label"
                    style="-fx-font-size:11px;-fx-text-fill:#64B5F6;" />
            </VBox>

            <!-- Menu Scrollable -->
            <ScrollPane fitToWidth="true"
                style="-fx-background:transparent;-fx-background-color:transparent;"
                VBox.vgrow="ALWAYS">
                <VBox spacing="0">

                    <!-- QUẢN LÝ MÁY -->
                    <Label text="QUẢN LÝ MÁY" styleClass="sidebar-section-label" />
                    <Button fx:id="btnSodoMay" text="🗺  Sơ Đồ Máy" styleClass="nav-button"
                        onAction="#showSodoMay" />
                    <Button fx:id="btnMayTinh" text="💻  Quản Lý Máy Tính" styleClass="nav-button"
                        onAction="#showMayTinh" />
                    <Button fx:id="btnKhuMay" text="📍  Khu Máy" styleClass="nav-button"
                        onAction="#showKhuMay" />
                    <Button fx:id="btnPhienSuDung" text="▶  Phiên Sử Dụng" styleClass="nav-button"
                        onAction="#showPhienSuDung" />

                    <!-- DỊCH VỤ & GÓI -->
                    <Label text="DỊCH VỤ - GÓI" styleClass="sidebar-section-label" />
                    <Button fx:id="btnDichVu" text="🛒  Dịch Vụ" styleClass="nav-button"
                        onAction="#showDichVu" />
                    <Button fx:id="btnGoiDichVu" text="📦  Gói Dịch Vụ" styleClass="nav-button"
                        onAction="#showGoiDichVu" />
                    <Button fx:id="btnKhuyenMai" text="🎁  Khuyến Mãi" styleClass="nav-button"
                        onAction="#showKhuyenMai" />

                    <!-- KHÁCH HÀNG & NV -->
                    <Label text="KHÁCH HÀNG &amp; NHÂN VIÊN" styleClass="sidebar-section-label" />
                    <Button fx:id="btnKhachHang" text="👤  Khách Hàng" styleClass="nav-button"
                        onAction="#showKhachHang" />
                    <Button fx:id="btnNapTien" text="💰  Nạp Tiền" styleClass="nav-button"
                        onAction="#showNapTien" />
                    <Button fx:id="btnNhanVien" text="👔  Nhân Viên" styleClass="nav-button"
                        onAction="#showNhanVien" />

                    <!-- TÀI CHÍNH -->
                    <Label text="TÀI CHÍNH &amp; KHO" styleClass="sidebar-section-label" />
                    <Button fx:id="btnHoaDon" text="🧾  Hóa Đơn" styleClass="nav-button"
                        onAction="#showHoaDon" />
                    <Button fx:id="btnNhapHang" text="📥  Nhập Hàng" styleClass="nav-button"
                        onAction="#showNhapHang" />

                    <!-- THỐNG KÊ -->
                    <Label text="BÁO CÁO" styleClass="sidebar-section-label" />
                    <Button fx:id="btnThongKe" text="📊  Thống Kê" styleClass="nav-button"
                        onAction="#showThongKe" />

                </VBox>
            </ScrollPane>

            <!-- Logout button -->
            <Button text="⏏  Đăng Xuất" styleClass="nav-button"
                onAction="#handleLogout"
                style="-fx-text-fill:#EF9A9A; -fx-border-color:#2C3E50; -fx-border-width:1 0 0 0;" />
        </VBox>
    </left>

    <!-- ====== MAIN CONTENT ====== -->
    <center>
        <VBox>
            <!-- Top header -->
            <HBox styleClass="top-header" alignment="CENTER_LEFT" spacing="12">
                <Label fx:id="lblPageTitle" text="Sơ Đồ Máy" styleClass="header-title"
                    HBox.hgrow="ALWAYS" />
                <Region HBox.hgrow="ALWAYS" />
                <VBox alignment="CENTER_RIGHT" spacing="2">
                    <Label fx:id="lblCurrentUser" text="Admin" styleClass="user-info-label" />
                    <Label fx:id="lblCurrentTime" text="--:--" styleClass="header-subtitle" />
                </VBox>
            </HBox>

            <!-- Content switcher -->
            <StackPane fx:id="contentPane" VBox.vgrow="ALWAYS"
                style="-fx-padding:0;" />
        </VBox>
    </center>

</BorderPane>