<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>
<?import javafx.collections.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="gui.controller.NhanVienController"
      stylesheets="@../css/style.css"
      spacing="16" styleClass="no-padding">

    <!-- Page Header -->
    <HBox alignment="CENTER_LEFT" spacing="12"
          styleClass="page-header-padding">
        <Label text="🏢" styleClass="page-icon"/>
        <VBox spacing="2">
            <Label text="Quản Lý Nhân Viên" styleClass="page-title"/>
            <Label fx:id="lblSubtitle" text="Đang tải..." styleClass="page-subtitle"/>
        </VBox>
    </HBox>

    <!-- Toolbar -->
    <HBox styleClass="toolbar" spacing="8" alignment="CENTER_LEFT">
        <TextField fx:id="txtSearch" promptText="🔍 Tìm kiếm..." styleClass="search-bar"
                   prefWidth="260" onKeyReleased="#handleSearch"/>
        <HBox spacing="15">
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label text="Chức vụ *" styleClass="form-label"/>
                <ComboBox fx:id="cboChucVu" promptText="Chọn chức vụ" styleClass="combo-box" maxWidth="Infinity"/>
            </VBox>
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label text="Trạng thái *" styleClass="form-label"/>
                <ComboBox fx:id="cboTrangThai" promptText="Trạng thái" styleClass="combo-box" prefWidth="140"/>
            </VBox>
        </HBox>

        <Pane HBox.hgrow="ALWAYS"/>
        <Button fx:id="btnThem" text="＋ Thêm" styleClass="btn btn-primary"
                onAction="#handleThem"/>
        <Button fx:id="btnSua" text="✎ Sửa" styleClass="btn btn-warning"
                onAction="#handleSua" disable="true"/>
        <Button fx:id="btnXoa" text="✕ Xóa" styleClass="btn btn-danger"
                onAction="#handleXoa" disable="true"/>
        <Button fx:id="btnLamMoi" text="↺ Làm mới" styleClass="btn btn-secondary"
                onAction="#handleLamMoi"/>
    </HBox>
    <VBox VBox.vgrow="ALWAYS" styleClass="page-card, no-padding" spacing="0">
        <TableView fx:id="tableView" VBox.vgrow="ALWAYS"
                   styleClass="table-rounded">
            <columns>
                <TableColumn fx:id="colMaNV" text="Mã NV" prefWidth="100"/>
                <TableColumn fx:id="colHoTen" text="Họ tên" prefWidth="250"/>
                <TableColumn fx:id="colTenDN" text="Tên đăng nhập" prefWidth="200"/>
                <TableColumn fx:id="colChucVu" text="Chức vụ" prefWidth="150"/>
                <TableColumn fx:id="colTrangThai" text="Trạng thái" prefWidth="150"/>
            </columns>
        </TableView>

        <HBox alignment="CENTER_RIGHT" spacing="12" styleClass="table-footer">
            <Label fx:id="lblTotal" text="Tổng: 0 bản ghi" styleClass="page-subtitle"/>
        </HBox>
    </VBox>

</VBox>
