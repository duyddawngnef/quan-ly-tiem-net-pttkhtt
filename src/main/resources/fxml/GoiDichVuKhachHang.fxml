<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<HBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="gui.controller.GoiDichVuKhachHangController" spacing="20"
      styleClass="manager-page-root">

       <!-- LEFT -->
       <VBox spacing="15" HBox.hgrow="ALWAYS">

              <VBox spacing="4">
                     <Label text="QUẢN LÝ GÓI DỊCH VỤ KHÁCH HÀNG"
                            styleClass="manager-title" />
                     <Label fx:id="lblSubtitle" text="..."
                            styleClass="manager-subtitle" />
              </VBox>

              <!-- TOOLBAR -->
              <HBox spacing="10" alignment="CENTER_LEFT" styleClass="manager-toolbar">

                     <ComboBox fx:id="cboViewMode" prefWidth="170"
                               onAction="#handleViewModeChange"
                               styleClass="manager-combo" />

                     <Separator orientation="VERTICAL" />

                     <TextField fx:id="txtSearch" prefWidth="210" onKeyReleased="#handleSearch"
                                styleClass="manager-search" />

                     <!-- Lọc trạng thái: chỉ hiện ở chế độ Tất cả gói -->
                     <ComboBox fx:id="cboFilterTrangThai" prefWidth="140"
                               styleClass="manager-combo" />

                     <!-- Lọc theo gói dịch vụ: chỉ hiện ở chế độ Tất cả gói -->
                     <ComboBox fx:id="cboFilterGoi" prefWidth="170"
                               styleClass="manager-combo" />

                     <Pane HBox.hgrow="ALWAYS" />

                     <Button fx:id="btnThem" onAction="#handleThem"
                             styleClass="btn-blue" />
                     <Button fx:id="btnLamMoi" onAction="#handleLamMoi"
                             styleClass="btn-gray" />
              </HBox>

              <!-- Thanh Back: chỉ hiện khi đang xem gói của 1 KH cụ thể -->
              <HBox fx:id="hboxBack" spacing="10" alignment="CENTER_LEFT"
                    visible="false" managed="false">
                     <Button fx:id="btnBack" onAction="#handleBack"
                             styleClass="btn-gray" />
                     <Label fx:id="lblKHMode" text="" styleClass="manager-subtitle" />
              </HBox>

              <!-- StackPane chính -->
              <StackPane VBox.vgrow="ALWAYS">

                     <!-- Bảng tất cả gói dịch vụ KH -->
                     <TableView fx:id="tableView"
                                styleClass="manager-table" visible="true" managed="true">
                            <columns>
                                   <TableColumn fx:id="colMaGoiKH"     prefWidth="110" styleClass="col-center" />
                                   <TableColumn fx:id="colMaKH"         prefWidth="80"  styleClass="col-center" />
                                   <TableColumn fx:id="colMaGoi"        prefWidth="80"  styleClass="col-center" />
                                   <TableColumn fx:id="colManv"         prefWidth="90"  styleClass="col-center" />
                                   <TableColumn fx:id="colSoGioBanDau"  prefWidth="90"  styleClass="col-center" />
                                   <TableColumn fx:id="colSoGioConLai"  prefWidth="90"  styleClass="col-center" />
                                   <TableColumn fx:id="colNgayMua"      prefWidth="130" styleClass="col-center" />
                                   <TableColumn fx:id="colNgayHetHan"   prefWidth="130" styleClass="col-center" />
                                   <TableColumn fx:id="colGiaMua"       prefWidth="110" styleClass="col-center" />
                                   <TableColumn fx:id="colTrangThai"    prefWidth="110" styleClass="col-center" />
                            </columns>
                            <columnResizePolicy>
                                   <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                     </TableView>

                     <!-- Bảng danh sách KH (chế độ Theo KH) -->
                     <TableView fx:id="tableKhachHang"
                                styleClass="manager-table" visible="false" managed="false">
                            <columns>
                                   <TableColumn fx:id="colKHMaKH"      prefWidth="120" styleClass="col-center" />
                                   <TableColumn fx:id="colKHTen"        prefWidth="220" styleClass="col-center" />
                                   <TableColumn fx:id="colKHSoDu"       prefWidth="160" styleClass="col-center" />
                                   <TableColumn fx:id="colKHTrangThai"  prefWidth="120" styleClass="col-center" />
                            </columns>
                            <columnResizePolicy>
                                   <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                     </TableView>

                     <!-- Bảng gói của 1 KH cụ thể -->
                     <TableView fx:id="tableGoiCuaKH"
                                styleClass="manager-table" visible="false" managed="false">
                            <columns>
                                   <TableColumn fx:id="colGKHMaGoiKH"     prefWidth="110" styleClass="col-center" />
                                   <TableColumn fx:id="colGKHMaGoi"       prefWidth="90"  styleClass="col-center" />
                                   <TableColumn fx:id="colGKHManv"        prefWidth="90"  styleClass="col-center" />
                                   <TableColumn fx:id="colGKHSoGioBanDau" prefWidth="90"  styleClass="col-center" />
                                   <TableColumn fx:id="colGKHSoGioConLai" prefWidth="90"  styleClass="col-center" />
                                   <TableColumn fx:id="colGKHNgayMua"     prefWidth="130" styleClass="col-center" />
                                   <TableColumn fx:id="colGKHNgayHetHan"  prefWidth="130" styleClass="col-center" />
                                   <TableColumn fx:id="colGKHGiaMua"      prefWidth="110" styleClass="col-center" />
                                   <TableColumn fx:id="colGKHTrangThai"   prefWidth="110" styleClass="col-center" />
                            </columns>
                            <columnResizePolicy>
                                   <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                     </TableView>

              </StackPane>

              <HBox alignment="CENTER_RIGHT">
                     <Label fx:id="lblTotal" text="..." styleClass="manager-total" />
              </HBox>

       </VBox>

       <!-- RIGHT: Form mua gói -->
       <ScrollPane fx:id="paneDetail" prefWidth="320" minWidth="280"
                   fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                   visible="false" managed="false"
                   styleClass="form-panel">

              <VBox spacing="16" styleClass="form-panel-content">

                     <Label text="MUA GÓI DỊCH VỤ" styleClass="form-title-dark" />

                     <!-- Ô 1: Khách hàng -->
                     <VBox spacing="6">
                            <Label text="Khách hàng *" styleClass="form-field-label" />

                            <ComboBox fx:id="cboChonKH" maxWidth="Infinity"
                                      editable="true" styleClass="manager-combo"
                                      onAction="#handleChonKH" />

                            <!-- Card thông tin KH đã chọn -->
                            <VBox fx:id="cardKH" spacing="0"
                                  visible="false" managed="false"
                                  style="-fx-background-color:#e8f4fd; -fx-background-radius:10; -fx-border-color:#90caf9; -fx-border-radius:10; -fx-border-width:1; -fx-padding:12;">
                                   <HBox spacing="12" alignment="CENTER_LEFT">
                                          <Label fx:id="lblAvatarKH"
                                                 style="-fx-background-color:#1565c0; -fx-background-radius:20; -fx-text-fill:white; -fx-font-weight:bold; -fx-font-size:16; -fx-min-width:40; -fx-min-height:40; -fx-max-width:40; -fx-max-height:40; -fx-alignment:center;" />
                                          <VBox spacing="2">
                                                 <Label fx:id="lblInfoTenKH"
                                                        style="-fx-font-weight:bold; -fx-font-size:14; -fx-text-fill:#1a1a2e;" />
                                                 <Label fx:id="lblInfoSdtKH"
                                                        style="-fx-font-size:12; -fx-text-fill:#666;" />
                                          </VBox>
                                   </HBox>
                                   <Separator style="-fx-padding:6 0;" />
                                   <HBox alignment="CENTER_LEFT" style="-fx-padding:6 0 0 0;" spacing="4">
                                          <Label text="Số dư hiện tại: "
                                                 style="-fx-font-size:13; -fx-text-fill:#555;" />
                                          <Label fx:id="lblInfoSoDuKH"
                                                 style="-fx-font-weight:bold; -fx-font-size:14; -fx-text-fill:#1565c0;" />
                                   </HBox>
                            </VBox>
                     </VBox>

                     <!-- Ô 2: Gói dịch vụ -->
                     <VBox spacing="6">
                            <Label text="Gói dịch vụ *" styleClass="form-field-label" />

                            <ListView fx:id="listGoiDichVu" prefHeight="135"
                                      styleClass="manager-table" />

                            <!-- Card thông tin gói đã chọn -->
                            <VBox fx:id="cardGoi" spacing="0"
                                  visible="false" managed="false"
                                  style="-fx-background-color:#f3f8ff; -fx-background-radius:10; -fx-border-color:#90caf9; -fx-border-radius:10; -fx-border-width:1; -fx-padding:12;">
                                   <HBox spacing="6" alignment="CENTER_LEFT">
                                          <Label fx:id="lblInfoMaGoi"
                                                 style="-fx-font-size:11; -fx-text-fill:white; -fx-background-color:#1976d2; -fx-background-radius:4; -fx-padding:2 7;" />
                                          <Label fx:id="lblInfoTenGoi"
                                                 style="-fx-font-weight:bold; -fx-font-size:13; -fx-text-fill:#1a1a2e;" />
                                   </HBox>
                                   <Separator style="-fx-padding:6 0;" />
                                   <HBox spacing="20" style="-fx-padding:6 0 0 0;">
                                          <VBox spacing="2">
                                                 <Label text="Số giờ"
                                                        style="-fx-font-size:11; -fx-text-fill:#888;" />
                                                 <Label fx:id="lblInfoSoGio"
                                                        style="-fx-font-weight:bold; -fx-font-size:14; -fx-text-fill:#1565c0;" />
                                          </VBox>
                                          <VBox spacing="2">
                                                 <Label text="Giá gói"
                                                        style="-fx-font-size:11; -fx-text-fill:#888;" />
                                                 <Label fx:id="lblInfoGia"
                                                        style="-fx-font-weight:bold; -fx-font-size:14; -fx-text-fill:#2e7d32;" />
                                          </VBox>
                                   </HBox>
                            </VBox>
                     </VBox>

                     <Pane prefHeight="4" />

                     <HBox spacing="10">
                            <Button fx:id="btnLuu" onAction="#handleLuuDetail"
                                    HBox.hgrow="ALWAYS" maxWidth="Infinity"
                                    styleClass="btn-save" />
                            <Button fx:id="btnHuy" onAction="#handleHuyDetail"
                                    HBox.hgrow="ALWAYS" maxWidth="Infinity"
                                    styleClass="btn-cancel" />
                     </HBox>

              </VBox>
       </ScrollPane>

</HBox>
