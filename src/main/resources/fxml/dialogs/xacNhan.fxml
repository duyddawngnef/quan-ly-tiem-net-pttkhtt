<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="gui.dialog.XacNhanDialog"
      stylesheets="@../../css/style.css"
      spacing="0" styleClass="dialog-root-md">

    <HBox styleClass="dialog-header" spacing="12" alignment="CENTER_LEFT">
        <Label fx:id="lblHeaderIcon" text="&#xe8fd;" styleClass="dialog-icon, icon"/>
        <Label fx:id="lblDialogTitle" text="Xác nhận" styleClass="dialog-title"/>
    </HBox>

    <VBox styleClass="dialog-body" spacing="16" alignment="CENTER">
        <Label fx:id="lblIcon" text="&#xe8fd;" styleClass="dialog-big-icon, icon-xl" alignment="CENTER"/>
        <Label fx:id="lblMessage" text="Bạn có chắc muốn thực hiện thao tác này?"
               wrapText="true" styleClass="dialog-message" maxWidth="400"/>
        <Label fx:id="lblSubMessage" text="" wrapText="true"
               styleClass="dialog-sub-message" maxWidth="400"/>
    </VBox>

    <HBox styleClass="dialog-footer" spacing="10" alignment="CENTER">
        <Button fx:id="btnCancel" styleClass="btn btn-secondary"
                prefWidth="120" onAction="#handleCancel">
            <graphic><Label text="&#xe5c9;" styleClass="icon-sm"/></graphic>
            <text>  Không</text>
        </Button>
        <Button fx:id="btnConfirm" styleClass="btn btn-primary"
                prefWidth="120" onAction="#handleConfirm">
            <graphic><Label text="&#xe876;" styleClass="icon-sm"/></graphic>
            <text>  Xác nhận</text>
        </Button>
    </HBox>

</VBox>
