<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<?import javafx.geometry.*?>
<!--        prefRowCount="3" wrapText="true"-->
<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="gui.dialog.ThemMayTinhDialog"
      stylesheets="@../../css/style.css"
      spacing="0" style="-fx-min-width:460; -fx-max-width:520;">

    <!-- Header -->
    <HBox styleClass="dialog-header" spacing="12" alignment="CENTER_LEFT">
        <Label text="💻" style="-fx-font-size:22px;"/>

        <Label fx:id="lblDialogTitle" text="Thêm / Sửa Máy Tính" styleClass="dialog-title"/>

    </HBox>

    <!-- Body -->
    <ScrollPane fitToWidth="true" style="-fx-background-color:transparent; -fx-border-color:transparent; -fx-max-height:480;">
        <VBox styleClass="dialog-body" spacing="12">
            <VBox spacing="4">
                <Label text="Mã máy *" styleClass="form-label"/>
                <TextField fx:id="txtMaMay" promptText="VD: PC001" styleClass="text-field" maxWidth="Infinity" disable="true"/>
                <Label fx:id="lbltxtMaMayError" styleClass="error-label" text=""/>
            </VBox>
            <VBox spacing="4">
                <Label text="Tên máy *" styleClass="form-label"/>
                <TextField fx:id="txtTenMay" promptText="VD: Máy 01" styleClass="text-field" maxWidth="Infinity"/>
                <Label fx:id="lbltxtTenMayError" styleClass="error-label" text=""/>
            </VBox>
            <VBox spacing="4">
                <Label text="Cấu hình *" styleClass="form-label"/>
                <TextField fx:id="txtCauHinh" promptText="VD: i5-10400F, 16GB RAM, GTX 1060" styleClass="text-field" maxWidth="Infinity" />
                <Label fx:id="lbltxtCauHinhError" styleClass="error-label" text=""/>
            </VBox>
            <VBox spacing="4">
                <Label text="Khu máy *" styleClass="form-label"/>
                <ComboBox fx:id="cboKhuMay" promptText="Chọn khu máy" styleClass="combo-box" maxWidth="Infinity"/>
                <Label fx:id="lblcboKhuMayError" styleClass="error-label" text=""/>
            </VBox>
            <VBox spacing="4">
                <Label text="Giá mỗi giờ (VNĐ) *" styleClass="form-label"/>
                <TextField fx:id="txtGiaMoiGio" promptText="VD: 10000" styleClass="text-field" maxWidth="Infinity"/>
                <Label fx:id="lbltxtGiaMoiGioError" styleClass="error-label" text=""/>
            </VBox>
            <VBox spacing="4">
                <Label text="Trạng thái" styleClass="form-label"/>
                <ComboBox fx:id="cboTrangThai" promptText="Chọn trạng thái" styleClass="combo-box" maxWidth="Infinity"/>
                <Label fx:id="lblcboTrangThaiError" styleClass="error-label" text=""/>
            </VBox>

            <Label fx:id="lblError" styleClass="error-label" text="" wrapText="true"/>
        </VBox>
    </ScrollPane>

    <!-- Footer -->
    <HBox styleClass="dialog-footer" spacing="10" alignment="CENTER_RIGHT">
        <Button fx:id="btnCancel" text="✕  Hủy" styleClass="btn btn-secondary"
                onAction="#handleCancel"/>
        <Button fx:id="btnSave" text="💾  Lưu" styleClass="btn btn-primary"
                onAction="#handleSave" />
    </HBox>

</VBox>