<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="gui.dialog.ThemMayTinhDialog"
      stylesheets="@../../css/style.css,@../../css/button.css,@../../css/dialog.css"
      spacing="0" style="-fx-min-width:500px;">

    <!-- Header -->
    <HBox styleClass="dialog-header" alignment="CENTER_LEFT">
        <Label fx:id="lblTitle" text="Thêm Máy Tính" styleClass="dialog-title"/>
    </HBox>

    <!-- Body -->
    <VBox styleClass="dialog-body" spacing="12">
        <GridPane hgap="14" vgap="12">
            <columnConstraints>
                <ColumnConstraints minWidth="110"/>
                <ColumnConstraints hgrow="ALWAYS"/>
                <ColumnConstraints minWidth="110"/>
                <ColumnConstraints hgrow="ALWAYS"/>
            </columnConstraints>

            <Label text="Mã máy:" styleClass="form-label" GridPane.rowIndex="0"/>
            <TextField fx:id="txtMaMay" editable="false" promptText="Tự động"
                       GridPane.rowIndex="0" GridPane.columnIndex="1"/>
            <Label text="Tên máy *:" styleClass="form-label" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
            <TextField fx:id="txtTenMay" GridPane.rowIndex="0" GridPane.columnIndex="3"/>

            <Label text="Khu máy *:" styleClass="form-label" GridPane.rowIndex="1"/>
            <ComboBox fx:id="cmbKhuMay" maxWidth="Infinity"
                      GridPane.rowIndex="1" GridPane.columnIndex="1"/>
            <Label text="Giá/giờ (đ) *:" styleClass="form-label" GridPane.rowIndex="1" GridPane.columnIndex="2"/>
            <TextField fx:id="txtGiaMoiGio" promptText="VD: 5000"
                       GridPane.rowIndex="1" GridPane.columnIndex="3"/>

            <Label text="CPU:" styleClass="form-label" GridPane.rowIndex="2"/>
            <TextField fx:id="txtCPU" promptText="VD: Core i5-10400F"
                       GridPane.rowIndex="2" GridPane.columnIndex="1"/>
            <Label text="RAM:" styleClass="form-label" GridPane.rowIndex="2" GridPane.columnIndex="2"/>
            <TextField fx:id="txtRAM" promptText="VD: 16GB DDR4"
                       GridPane.rowIndex="2" GridPane.columnIndex="3"/>

            <Label text="VGA:" styleClass="form-label" GridPane.rowIndex="3"/>
            <TextField fx:id="txtVGA" promptText="VD: GTX 1060 6GB"
                       GridPane.rowIndex="3" GridPane.columnIndex="1"/>
            <Label text="Màn hình:" styleClass="form-label" GridPane.rowIndex="3" GridPane.columnIndex="2"/>
            <TextField fx:id="txtManHinh" promptText="VD: 24 inch Full HD"
                       GridPane.rowIndex="3" GridPane.columnIndex="3"/>

            <Label text="Trạng thái:" styleClass="form-label" GridPane.rowIndex="4"/>
            <ComboBox fx:id="cmbTrangThai" maxWidth="Infinity"
                      GridPane.rowIndex="4" GridPane.columnIndex="1"/>

            <Label text="Ghi chú:" styleClass="form-label" GridPane.rowIndex="5"/>
            <TextArea fx:id="txtGhiChu" prefRowCount="2" wrapText="true"
                      GridPane.rowIndex="5" GridPane.columnIndex="1" GridPane.columnSpan="3"/>
        </GridPane>
        <Label fx:id="lblError" style="-fx-text-fill:#E53935;-fx-font-weight:bold;" text="" wrapText="true"/>
    </VBox>

    <!-- Footer -->
    <HBox styleClass="dialog-footer" spacing="10">
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="Hủy" styleClass="btn-secondary" onAction="#handleCancel"/>
        <Button text="💾 Lưu" styleClass="btn-primary" onAction="#handleSave" defaultButton="true"/>
    </HBox>
</VBox>