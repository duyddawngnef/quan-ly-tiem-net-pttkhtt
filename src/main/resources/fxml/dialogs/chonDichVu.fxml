<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="0" styleClass="dialog-root-xl" stylesheets="@../../css/style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.dialog.ChonDichVuDialog">

    <HBox alignment="CENTER_LEFT" spacing="12" styleClass="dialog-header">
        <Label styleClass="dialog-icon" text="🥤" />
        <VBox spacing="2">
            <Label styleClass="dialog-title" text="Order Dịch Vụ" />
            <Label fx:id="lblPhienInfo" styleClass="dialog-phien-info" text="Phiên: ..." />
        </VBox>
    </HBox>

    <VBox spacing="12" styleClass="dialog-body">
        <!-- Search -->
        <TextField fx:id="txtSearch" onKeyReleased="#handleSearch" promptText="🔍  Tìm dịch vụ..." styleClass="search-bar" />

        <!-- DV list table -->
        <TableView fx:id="tableDichVu" prefHeight="220">
            <columns>
                <TableColumn fx:id="colDVMa" prefWidth="80" text="Mã DV" />
                <TableColumn fx:id="colDVTen" prefWidth="200" text="Tên dịch vụ" />
                <TableColumn fx:id="colDVGia" prefWidth="100" text="Đơn giá" />
                <TableColumn fx:id="colDVTon" prefWidth="90" text="Tồn kho" />
            </columns>
        </TableView>

        <!-- Selected item + quantity -->
        <HBox alignment="CENTER_LEFT" spacing="10" styleClass="dialog-order-summary">
            <VBox spacing="3" HBox.hgrow="ALWAYS">
                <Label styleClass="detail-label, font-12" text="Dịch vụ đã chọn:" />
                <Label fx:id="lblSelectedDV" styleClass="text-bold, font-12" text="Chưa chọn dịch vụ" />
            </VBox>
            <VBox alignment="CENTER" spacing="4">
                <Label styleClass="form-label" text="Số lượng:" />
                <HBox alignment="CENTER" spacing="4">
                    <Button onAction="#handleDecrease" styleClass="btn btn-secondary, dialog-qty-btn" text="−" />
                    <TextField fx:id="txtSoLuong" prefWidth="60" styleClass="text-field, dialog-qty-field" text="1" />
                    <Button onAction="#handleIncrease" styleClass="btn btn-primary, dialog-qty-btn" text="＋" />
                </HBox>
            </VBox>
        </HBox>

        <!-- Cart / order list -->
        <Label styleClass="section-title-bold" text="Giỏ hàng:" />
        <TableView fx:id="tableCart" prefHeight="150">
            <columns>
                <TableColumn fx:id="colCartTen" prefWidth="200" text="Dịch vụ" />
                <TableColumn fx:id="colCartSL" prefWidth="50" text="SL" />
                <TableColumn fx:id="colCartDonGia" prefWidth="100" text="Đơn giá" />
                <TableColumn fx:id="colCartThanhTien" prefWidth="110" text="Thành tiền" />
                <TableColumn fx:id="colCartXoa" prefWidth="50" text="" />
            </columns>

        </TableView>

        <HBox alignment="CENTER_RIGHT">
            <Label styleClass="text-bold" text="Tổng tiền order: " />
            <Label fx:id="lblTongTienCart" styleClass="currency-label" text="0 ₫" />
        </HBox>

        <Label fx:id="lblError" styleClass="error-label" text="" />
    </VBox>

    <HBox alignment="CENTER_RIGHT" spacing="10" styleClass="dialog-footer">
        <Button onAction="#handleAddToCart" styleClass="btn btn-outline" text="＋  Thêm vào giỏ" />
        <Pane HBox.hgrow="ALWAYS" />
        <Button onAction="#handleRemoveFromCart" styleClass="btn btn-secondary" text="✕  Hủy" />
        <Button fx:id="btnXacNhan" onAction="#handleXacNhan" styleClass="btn btn-success" text="✔  Xác nhận order" />
    </HBox>

</VBox>
