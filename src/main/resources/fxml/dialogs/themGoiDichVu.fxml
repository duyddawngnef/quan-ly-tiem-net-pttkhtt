<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="gui.dialog.ThemGoiDichVuDialog"
      stylesheets="@../../css/style.css"
      spacing="0" styleClass="dialog-root-lg">

    <!-- Header -->
    <HBox styleClass="dialog-header" spacing="12" alignment="CENTER_LEFT">
        <Label text="📦" styleClass="dialog-icon"/>
        <Label fx:id="lblDialogTitle" text="Thêm / Sửa Gói Dịch Vụ" styleClass="dialog-title"/>
    </HBox>

    <!-- Body -->
    <ScrollPane fitToWidth="true" styleClass="dialog-scroll-max">
        <VBox styleClass="dialog-body" spacing="12">
            <VBox spacing="4">
                <Label text="Mã gói *" styleClass="form-label"/>
                <TextField fx:id="txtMaGoi" promptText="VD: GOIGIO5" styleClass="text-field" maxWidth="Infinity"/>
                <Label fx:id="lbltxtMaGoiError" styleClass="error-label" text=""/>
            </VBox>
            <VBox spacing="4">
                <Label text="Tên gói *" styleClass="form-label"/>
                <TextField fx:id="txtTenGoi" promptText="VD: Gói 5 giờ" styleClass="text-field" maxWidth="Infinity"/>
                <Label fx:id="lbltxtTenGoiError" styleClass="error-label" text=""/>
            </VBox>
            <VBox spacing="4">
                <Label text="Giá gói (VNĐ) *" styleClass="form-label"/>
                <TextField fx:id="txtGia" promptText="VD: 45000" styleClass="text-field" maxWidth="Infinity"/>
                <Label fx:id="lbltxtGiaError" styleClass="error-label" text=""/>
            </VBox>
            <VBox spacing="4">
                <Label text="Số giờ *" styleClass="form-label"/>
                <TextField fx:id="txtSoGio" promptText="VD: 5" styleClass="text-field" maxWidth="Infinity"/>
                <Label fx:id="lbltxtSoGioError" styleClass="error-label" text=""/>
            </VBox>
            <VBox spacing="4">
                <Label text="Mô tả" styleClass="form-label"/>
                <TextArea fx:id="txtMoTa" promptText="Mô tả ưu đãi..." styleClass="text-field" maxWidth="Infinity" prefRowCount="3" wrapText="true"/>
                <Label fx:id="lbltxtMoTaError" styleClass="error-label" text=""/>
            </VBox>
            <VBox spacing="4">
                <Label text="Trạng thái" styleClass="form-label"/>
                <ComboBox fx:id="cboTrangThai" promptText="Chọn trạng thái" styleClass="combo-box" maxWidth="Infinity"/>
                <Label fx:id="lblcboTrangThaiError" styleClass="error-label" text=""/>
            </VBox>

            <Label fx:id="lblError" styleClass="error-label" text="" wrapText="true"/>
        </VBox>
    </ScrollPane>

    <!-- Footer -->
    <HBox styleClass="dialog-footer" spacing="10" alignment="CENTER_RIGHT">
        <Button text="✕  Hủy" styleClass="btn btn-secondary"
                onAction="#handleCancel"/>
        <Button fx:id="btnSave" text="💾  Lưu" styleClass="btn btn-primary"
                onAction="#handleSave"/>
    </HBox>

</VBox>
