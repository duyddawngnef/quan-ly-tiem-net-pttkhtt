<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="gui.controller.ThongKeController"
      stylesheets="@../css/style.css"
      spacing="16" styleClass="no-padding">

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="12">
        <Label text="&#xe26b;" styleClass="page-icon, icon-lg"/>
        <VBox spacing="2">
            <Label text="Thống Kê &amp; Báo Cáo" styleClass="page-title"/>
            <Label text="Phân tích doanh thu, chi phí và lợi nhuận" styleClass="page-subtitle"/>
        </VBox>
    </HBox>

    <!-- Summary cards -->
    <HBox spacing="12">
        <VBox styleClass="stat-card stat-card-green" spacing="4" HBox.hgrow="ALWAYS">
            <Label fx:id="lblTongThu" text="0 ₫" styleClass="stat-number, stat-number-small, stat-number-green"/>
            <Label text="Tổng thu (tháng này)" styleClass="stat-label"/>
        </VBox>
        <VBox styleClass="stat-card stat-card-red" spacing="4" HBox.hgrow="ALWAYS">
            <Label fx:id="lblTongChi" text="0 ₫" styleClass="stat-number, stat-number-small, stat-number-red"/>
            <Label text="Tổng chi (ước tính)" styleClass="stat-label"/>
        </VBox>
        <VBox styleClass="stat-card stat-card-blue" spacing="4" HBox.hgrow="ALWAYS">
            <Label fx:id="lblLoiNhuan" text="0 ₫" styleClass="stat-number, stat-number-small, stat-number-blue"/>
            <Label text="Doanh thu hôm nay" styleClass="stat-label"/>
        </VBox>
        <VBox styleClass="stat-card" spacing="4" HBox.hgrow="ALWAYS">
            <Label fx:id="lblSoPhien" text="0" styleClass="stat-number"/>
            <Label text="Phiên đang chơi" styleClass="stat-label"/>
        </VBox>
    </HBox>

    <TabPane VBox.vgrow="ALWAYS" tabClosingPolicy="UNAVAILABLE">

        <!-- Tab 1 -->
        <Tab text="  Doanh thu">
            <VBox spacing="12" styleClass="tab-content-padding">
                <HBox spacing="10" alignment="CENTER_LEFT" styleClass="toolbar">
                    <Label text="Loại:" styleClass="text-muted"/>
                    <ComboBox fx:id="cboLoaiTK" styleClass="combo-box" prefWidth="160"
                              onAction="#handleLoaiTKChanged"/>
                    <DatePicker fx:id="dateFrom" promptText="Từ ngày" prefWidth="130"/>
                    <DatePicker fx:id="dateTo" promptText="Đến ngày" prefWidth="130"/>
                    <Button styleClass="btn btn-primary" onAction="#handleThongKe">
                        <graphic><Label text="&#xe26b;" styleClass="icon-sm"/></graphic>
                        <text>  Thống kê</text>
                    </Button>
                    <Pane HBox.hgrow="ALWAYS"/>
                    <Button styleClass="btn btn-success" onAction="#handleXuatExcel">
                        <graphic><Label text="&#xeb9e;" styleClass="icon-sm"/></graphic>
                        <text>  Xuất Excel</text>
                    </Button>
                </HBox>

                <SplitPane dividerPositions="0.55" VBox.vgrow="ALWAYS">
                    <VBox styleClass="page-card, no-padding" spacing="0">
                        <Label text="Bảng dữ liệu"
                               styleClass="section-title-blue-padded"/>
                        <TableView fx:id="tableThongKe" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colThoiGian" text="Thời gian" prefWidth="220"/>
                                <TableColumn fx:id="colDoanhThu" text="Doanh thu" prefWidth="150"/>
                                <TableColumn fx:id="colNhapHang" text="Nhập hàng" prefWidth="150"/>
                                <TableColumn fx:id="colLoiNhuanCol" text="Lợi nhuận" prefWidth="150"/>
                            </columns>
                        </TableView>
                    </VBox>

                    <VBox styleClass="page-card" spacing="10">
                        <Label fx:id="lblChartPlaceholder"
                               text="Nhấn 'Thống kê' để hiển thị biểu đồ"
                               styleClass="chart-placeholder"/>
                        <StackPane fx:id="chartContainer" VBox.vgrow="ALWAYS" maxWidth="Infinity"/>
                    </VBox>
                </SplitPane>
            </VBox>
        </Tab>

        <!-- Tab 2 -->
        <Tab text="  Thu - Chi - Lợi nhuận">
            <VBox spacing="12" styleClass="tab-content-padding">
                <HBox spacing="10" alignment="CENTER_LEFT" styleClass="toolbar">
                    <Label text="Khoảng thời gian:" styleClass="text-muted"/>
                    <ComboBox fx:id="cboThoiGian" styleClass="combo-box" prefWidth="160"/>
                    <DatePicker fx:id="dateTCFrom" promptText="Từ ngày" prefWidth="130"/>
                    <DatePicker fx:id="dateTCTo" promptText="Đến ngày" prefWidth="130"/>
                    <Button styleClass="btn btn-primary" onAction="#handleThongKeThuChi">
                        <graphic><Label text="&#xe26b;" styleClass="icon-sm"/></graphic>
                        <text>  Xem</text>
                    </Button>
                </HBox>

                <TableView fx:id="tableThuChi" VBox.vgrow="ALWAYS" styleClass="page-card, no-padding">
                    <columns>
                        <TableColumn fx:id="colTCThoiGian" text="Thời gian" prefWidth="180"/>
                        <TableColumn fx:id="colTCThu" text="Tổng thu (₫)" prefWidth="160"/>
                        <TableColumn fx:id="colTCChi" text="Tổng chi (₫)" prefWidth="160"/>
                        <TableColumn fx:id="colTCLoiNhuan" text="Lợi nhuận (₫)" prefWidth="160"/>
                    </columns>
                </TableView>
            </VBox>
        </Tab>

        <!-- Tab 3 -->
        <Tab text="  Top khách hàng">
            <VBox spacing="12" styleClass="tab-content-padding">
                <HBox spacing="10" alignment="CENTER_LEFT" styleClass="toolbar">
                    <Label text="Năm:" styleClass="text-muted"/>
                    <ComboBox fx:id="cboNamTop" styleClass="combo-box" prefWidth="100"/>
                    <Label text="Hiển thị top:" styleClass="text-muted"/>
                    <ComboBox fx:id="cboTopN" styleClass="combo-box" prefWidth="100"/>
                    <Button styleClass="btn btn-primary" onAction="#handleThongKeTop">
                        <graphic><Label text="&#xe26b;" styleClass="icon-sm"/></graphic>
                        <text>  Xem</text>
                    </Button>
                </HBox>

                <TableView fx:id="tableTop" VBox.vgrow="ALWAYS" styleClass="page-card, no-padding">
                    <columns>
                        <TableColumn fx:id="colTopSTT" text="STT" prefWidth="60"/>
                        <TableColumn fx:id="colTopTen" text="Khách hàng" prefWidth="220"/>
                        <TableColumn fx:id="colTopSoPhien" text="Số phiên" prefWidth="100"/>
                        <TableColumn fx:id="colTopThoiGian" text="Tổng giờ" prefWidth="120"/>
                        <TableColumn fx:id="colTopTongTien" text="Tổng chi tiêu (₫)" prefWidth="180"/>
                    </columns>
                </TableView>
            </VBox>
        </Tab>

    </TabPane>
</VBox>