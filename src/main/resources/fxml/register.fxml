<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<StackPane xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="gui.controller.RegisterController"
           stylesheets="@../css/login.css, @../css/style.css"
           styleClass="login-root">

    <ScrollPane fitToWidth="true" fitToHeight="true">
        <VBox alignment="CENTER" spacing="0" styleClass="register-center-padding">

            <VBox styleClass="login-card, register-card-size" spacing="14">

                <!-- Header -->
                <VBox alignment="CENTER" spacing="6" styleClass="register-header-padding">
                    <Label text="&#xe3c9;" styleClass="register-icon, icon-xl"/>
                    <Label text="ĐĂNG KÝ TÀI KHOẢN" styleClass="login-title"/>
                    <Label text="Tạo tài khoản khách hàng mới" styleClass="login-subtitle"/>
                </VBox>

                <Separator/>

                <!-- Name row -->
                <HBox spacing="12">
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="Họ *" styleClass="form-label"/>
                        <TextField fx:id="txtHo" promptText="Nhập họ" styleClass="text-field" maxWidth="Infinity"/>
                    </VBox>
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="Tên *" styleClass="form-label"/>
                        <TextField fx:id="txtTen" promptText="Nhập tên" styleClass="text-field" maxWidth="Infinity"/>
                    </VBox>
                </HBox>

                <!-- Phone -->
                <VBox spacing="4">
                    <Label text="Số điện thoại *" styleClass="form-label"/>
                    <TextField fx:id="txtSoDienThoai" promptText="VD: 0912345678"
                               styleClass="text-field" maxWidth="Infinity"/>
                </VBox>

                <!-- Username -->
                <VBox spacing="4">
                    <Label text="Tên đăng nhập *" styleClass="form-label"/>
                    <TextField fx:id="txtTenDangNhap" promptText="Tối thiểu 6 ký tự"
                               styleClass="text-field" maxWidth="Infinity"/>
                    <Label fx:id="lblUserError" styleClass="error-label" text=""/>
                </VBox>

                <!-- Password -->
                <VBox spacing="4">
                    <Label text="Mật khẩu *" styleClass="form-label"/>
                    <PasswordField fx:id="txtMatKhau" promptText="Tối thiểu 6 ký tự"
                                   styleClass="text-field" maxWidth="Infinity"/>
                </VBox>

                <!-- Confirm Password -->
                <VBox spacing="4">
                    <Label text="Xác nhận mật khẩu *" styleClass="form-label"/>
                    <PasswordField fx:id="txtXacNhanMk" promptText="Nhập lại mật khẩu"
                                   styleClass="text-field" maxWidth="Infinity"/>
                    <Label fx:id="lblPassError" styleClass="error-label" text=""/>
                </VBox>

                <!-- Error area -->
                <Label fx:id="lblError" styleClass="login-error-label" text="" wrapText="true"/>

                <!-- Buttons -->
                <VBox spacing="8" styleClass="register-buttons-padding">
                    <Button fx:id="btnDangKy" text="ĐĂNG KÝ" styleClass="login-btn"
                            maxWidth="Infinity" onAction="#handleDangKy"/>
                    <Button text="← Quay lại đăng nhập" styleClass="login-register-link, register-back-btn"
                            maxWidth="Infinity"
                            onAction="#handleBackToLogin"/>
                </VBox>

            </VBox>
        </VBox>
    </ScrollPane>
</StackPane>
