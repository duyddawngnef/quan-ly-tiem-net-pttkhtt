<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="gui.controller.MayTinhController"
      spacing="14" style="-fx-padding:20;">

    <HBox styleClass="card" alignment="CENTER_LEFT" spacing="12"
          style="-fx-padding:12 16;-fx-background-radius:8;">
        <TextField fx:id="txtSearch" styleClass="search-field" promptText="🔍 Tìm mã máy, tên máy..."/>
        <ComboBox fx:id="cmbKhuMay" promptText="Khu máy" style="-fx-min-width:140px;"/>
        <ComboBox fx:id="cmbTrangThai" promptText="Trạng thái" style="-fx-min-width:130px;"/>
        <Button text="Tìm" styleClass="btn-primary,btn-sm" onAction="#handleSearch"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="+ Thêm" styleClass="btn-success" onAction="#handleThem"/>
        <Button fx:id="btnSua" text="✏ Sửa" styleClass="btn-warning" onAction="#handleSua"/>
        <Button fx:id="btnXoa" text="✕ Xóa" styleClass="btn-danger" onAction="#handleXoa"/>
    </HBox>

    <HBox spacing="14" VBox.vgrow="ALWAYS">
        <VBox styleClass="card" HBox.hgrow="ALWAYS" spacing="0" style="-fx-padding:0;-fx-background-radius:8;">
            <Label text="Danh Sách Máy Tính"
                   style="-fx-font-size:14px;-fx-font-weight:bold;-fx-text-fill:#1E2A3A;-fx-padding:12 16;"/>
            <TableView fx:id="tableMayTinh" VBox.vgrow="ALWAYS" onMouseClicked="#handleRowSelect">
                <columns>
                    <TableColumn fx:id="colMaMay" text="Mã Máy" prefWidth="90"/>
                    <TableColumn fx:id="colTenMay" text="Tên Máy" prefWidth="130"/>
                    <TableColumn fx:id="colKhuMay" text="Khu" prefWidth="100"/>
                    <TableColumn fx:id="colGiaMoiGio" text="Giá/Giờ (đ)" prefWidth="120"/>
                    <TableColumn fx:id="colCauHinh" text="Cấu Hình" prefWidth="200"/>
                    <TableColumn fx:id="colTrangThai" text="Trạng Thái" prefWidth="120"/>
                    <TableColumn fx:id="colGhiChu" text="Ghi Chú" prefWidth="150"/>
                </columns>
            </TableView>
        </VBox>

        <VBox styleClass="card" minWidth="300" maxWidth="320" spacing="12">
            <Label fx:id="lblFormTitle" text="Thông Tin Máy Tính"
                   style="-fx-font-size:14px;-fx-font-weight:bold;-fx-text-fill:#1E2A3A;"/>
            <Separator/>
            <GridPane hgap="8" vgap="10">
                <columnConstraints>
                    <ColumnConstraints minWidth="95"/>
                    <ColumnConstraints hgrow="ALWAYS"/>
                </columnConstraints>
                <Label text="Mã máy:" styleClass="form-label" GridPane.rowIndex="0"/>
                <TextField fx:id="txtMaMay" editable="false" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                <Label text="Tên máy *:" styleClass="form-label" GridPane.rowIndex="1"/>
                <TextField fx:id="txtTenMay" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                <Label text="Khu máy *:" styleClass="form-label" GridPane.rowIndex="2"/>
                <ComboBox fx:id="cmbKhuMayForm" GridPane.rowIndex="2" GridPane.columnIndex="1" maxWidth="Infinity"/>

                <Label text="Giá/giờ (đ) *:" styleClass="form-label" GridPane.rowIndex="3"/>
                <TextField fx:id="txtGiaMoiGio" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

                <Label text="CPU:" styleClass="form-label" GridPane.rowIndex="4"/>
                <TextField fx:id="txtCPU" promptText="VD: i5-10400F" GridPane.rowIndex="4" GridPane.columnIndex="1"/>

                <Label text="RAM:" styleClass="form-label" GridPane.rowIndex="5"/>
                <TextField fx:id="txtRAM" promptText="VD: 16GB" GridPane.rowIndex="5" GridPane.columnIndex="1"/>

                <Label text="VGA:" styleClass="form-label" GridPane.rowIndex="6"/>
                <TextField fx:id="txtVGA" GridPane.rowIndex="6" GridPane.columnIndex="1"/>

                <Label text="Trạng thái:" styleClass="form-label" GridPane.rowIndex="7"/>
                <ComboBox fx:id="cmbTrangThaiForm" GridPane.rowIndex="7" GridPane.columnIndex="1" maxWidth="Infinity"/>

                <Label text="Ghi chú:" styleClass="form-label" GridPane.rowIndex="8"/>
                <TextArea fx:id="txtGhiChu" GridPane.rowIndex="8" GridPane.columnIndex="1"
                          prefRowCount="2" wrapText="true"/>
            </GridPane>
            <Region VBox.vgrow="ALWAYS"/>
            <HBox spacing="8">
                <Button text="💾 Lưu" styleClass="btn-primary" maxWidth="Infinity" HBox.hgrow="ALWAYS" onAction="#handleSave"/>
                <Button text="✕ Hủy" styleClass="btn-secondary" maxWidth="Infinity" HBox.hgrow="ALWAYS" onAction="#handleCancel"/>
            </HBox>
        </VBox>
    </HBox>
</VBox>